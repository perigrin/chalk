#!/usr/bin/env perl
# ABOUTME: Per-class XS bootstrap: parse each class → IR → individual XS module.
# ABOUTME: Each class gets its own .so for independent loading without bridge overhead.
use 5.42.0;
use utf8;

use File::Path qw(make_path remove_tree);
use File::Basename qw(dirname);

use lib 'lib';
use lib 't/bootstrap/lib';

use TestXSHelpers qw(setup_xs_grammar parse_file_ir);
use Chalk::Bootstrap::Perl::Target::XS;

my $build_dir = '.build/xs';

my $total_t0 = time();

# === Phase 1: Grammar pipeline ===
my $t0 = time();
print "Phase 1: Building grammar pipeline...\n";
my $grammar = setup_xs_grammar('Chalk::Grammar::Perl::XSBootstrap');
printf "Phase 1: %.1fs\n\n", time() - $t0;

# === Phase 2-3: Parse each class and generate per-class XS ===
# Each class is compiled independently into its own XS module.
# This avoids multi-class BOOT issues and keeps each .so independent.
#
# NOTE: Do NOT bundle these into a single multi-class module.
# generate_distribution_multi_class was abandoned because _run_parse
# falls back to eval_pv regardless, making multi-class no faster
# than pure Perl. Per-class + semiring intrinsics is the correct path.
my @source_files = (
    ['Chalk::Bootstrap::Semiring::Boolean',          'lib/Chalk/Bootstrap/Semiring/Boolean.pm'],
    ['Chalk::Bootstrap::Semiring::Precedence',       'lib/Chalk/Bootstrap/Semiring/Precedence.pm'],
    ['Chalk::Bootstrap::Semiring::Structural',       'lib/Chalk/Bootstrap/Semiring/Structural.pm'],
    ['Chalk::Bootstrap::Semiring::TypeInference',    'lib/Chalk/Bootstrap/Semiring/TypeInference.pm'],
    ['Chalk::Bootstrap::Semiring::SemanticAction',   'lib/Chalk/Bootstrap/Semiring/SemanticAction.pm'],
    ['Chalk::Bootstrap::Semiring::FilterComposite',  'lib/Chalk/Bootstrap/Semiring/FilterComposite.pm'],
    ['Chalk::Bootstrap::Earley',                     'lib/Chalk/Bootstrap/Earley.pm'],
);

$t0 = time();
print "Phase 2-3: Parse and generate per-class XS...\n";
my %all_dists;  # class_name => { dist => $dist, build_subdir => $subdir }

for my $spec (@source_files) {
    my ($class_name, $file) = $spec->@*;
    my $short = $file =~ s{.*/}{}r;
    my $file_t0 = time();

    # Parse
    my ($ir, $sa, $ctx, $cfg_snapshot) = parse_file_ir($grammar, $file);
    die "Failed to parse $file" unless defined $ir;

    # Generate per-class XS distribution
    my $module_name = "${class_name}::XS";
    my $xs = Chalk::Bootstrap::Perl::Target::XS->new(
        module_name => $module_name,
    );
    my $dist = eval { $xs->generate_distribution_with_cfg($ir, $sa, $ctx) };
    die "XS generation failed for $class_name: $@" unless ref($dist) eq 'HASH';

    # Use a slug for the build subdirectory
    my $slug = $class_name;
    $slug =~ s/::/-/g;

    $all_dists{$class_name} = { dist => $dist, slug => $slug, module_name => $module_name };
    printf "  %s: %.1fs\n", $short, time() - $file_t0;
}
printf "Phase 2-3 total: %.1fs\n\n", time() - $t0;

# === Phase 4: Write and build each module ===
$t0 = time();
print "Phase 4: Writing and compiling per-class XS...\n";

remove_tree($build_dir) if -d $build_dir;
make_path($build_dir);

my @load_paths;  # collect blib paths for the final load instructions

for my $class_name (sort keys %all_dists) {
    my $info = $all_dists{$class_name};
    my $dist = $info->{dist};
    my $slug = $info->{slug};
    my $subdir = "$build_dir/$slug";

    make_path($subdir);
    for my $path (sort keys $dist->%*) {
        my $full_path = "$subdir/$path";
        my $dir = dirname($full_path);
        make_path($dir) unless -d $dir;
        open(my $wfh, '>:encoding(UTF-8)', $full_path) or die "Cannot write $full_path: $!";
        print $wfh $dist->{$path};
        close $wfh;
    }

    my $libs = join(':', 'lib', $ENV{PERL5LIB} // '');
    my $build_ok = system(qq{cd "$subdir" && "$^X" Build.PL 2>&1 && PERL5LIB="$libs" "$^X" Build 2>&1});
    if ($build_ok != 0) {
        warn "Build failed for $class_name (exit $build_ok), skipping\n";
        next;
    }

    push @load_paths, "$subdir/blib/lib", "$subdir/blib/arch";
    printf "  %s: OK\n", $slug;
}
printf "Phase 4: %.1fs\n\n", time() - $t0;

# === Done ===
my $total = time() - $total_t0;
printf "Bootstrap complete in %.0fs (%.1f minutes)\n", $total, $total / 60;
print "Load with:\n";
for my $path (@load_paths) {
    print "  use lib '$path';\n";
}
for my $class_name (sort keys %all_dists) {
    print "  require $all_dists{$class_name}{module_name};\n";
}
