use 5.42.0;
use experimental qw(class builtin);
use utf8;
use open qw/:std :utf8/;

class Element {
    use overload
      '+'      => 'add',
      '*'      => 'multiply',
      '""'     => 'to_string',
      '=='     => 'equals',
      fallback => 1;

    method add( $other, $swap      = undef ) { ... }
    method multiply( $other, $swap = undef ) { ... }
    method equals( $other, $swap   = undef ) { ... }

    method score()     { ... }
    method to_string() { ... }
}

class Semiring {
    method init_element_from_rule($rule) { ... }
}

class BooleanElement :isa(Element) {
    field $value :param :reader;

    method multiply( $other, $swap = undef ) {
        BooleanElement->new( value => $value && $other->value );
    }

    method add( $other, $swap = undef ) {
        BooleanElement->new( value => $value || $other->value );
    }

    method equals( $other, $swap = undef ) {
        return 0 unless ref($other) eq ref($self);
        return $value == $other->value;
    }

    method to_string(@) { $value ? 'true' : 'false' }
}

class BooleanSemiring :isa(Semiring) {
    field $mul_id :reader = BooleanElement->new( value => 1 );
    field $add_id :reader = BooleanElement->new( value => 0 );
    field $root_element = BooleanElement->new( value => 1 );

    method init_element_from_rule($rule) {
        BooleanElement->new( value => $rule->probability > 0 ? 1 : 0 );
    }
}

class ViterbiElement :isa(Element) {
    field $score :param :reader;
    field $path  :param :reader;

    method multiply( $other, $swap = undef ) {

        return ViterbiElement->new(
            score => $score + $other->score,
            path  => [ $path->@*, $other->path->@* ],
        );
    }

    method add( $other, $swap = undef ) {
        return $self if $score > $other->score;
        return $other;
    }

    method equals( $other, $swap = undef ) {
        return 0 unless ref($other) eq ref($self);
        return $score == $other->score
          && join( ',', $path->@* ) eq join( ',', $other->path->@* );
    }

    method to_string(@) {
        return sprintf '%.4f[%s]', exp($score), join ',', $path->@*;
    }

    method probability() { exp($score) }
    method best_path()   { $path->[0] }
}

class ViterbiSemiring :isa(Semiring) {
    field $root_element :param :reader = ViterbiElement->new(
        score => 0,
        path  => [],
    );
    field $mul_id :reader = ViterbiElement->new(
        score => 0,
        path  => ['ε'],
    );
    field $add_id :reader = ViterbiElement->new(
        score => -1e10,
        path  => [],
    );

    method init_element_from_rule($rule) {
        ViterbiElement->new(
            score => log( $rule->probability ),
            path  => [$rule]
        );
    }
}

class EarleyItem {
    use overload '""' => 'key';

    field $start_pos :param :reader;
    field $rule      :param :reader;
    field $dot_pos   :param :reader;
    field $end_pos   :param :reader;

    method is_complete() { $dot_pos >= scalar( $rule->rhs->@* ) }

    method next_symbol() {
        return if $self->is_complete;
        return $rule->rhs->[$dot_pos];
    }

    method advance_dot() {
        EarleyItem->new(
            start_pos => $start_pos,
            rule      => $rule,
            dot_pos   => $dot_pos + 1,
            end_pos   => $end_pos,
        );
    }

    method key(@) {
        return "$start_pos|" . $rule->id . "|$dot_pos|$end_pos";
    }
}

class EarleyChart {
    field $semiring :param;
    field %chart;
    field %by_end_pos;
    field %by_start_pos;

    method add_item($earley_item) {
        $chart{ $earley_item->key } = $earley_item;
    }

    method get_element($key) { $chart{$key} }

    method add_element( $item, $element ) {
        my $key     = $item->key;
        my $current = $self->get_element($key);
        $chart{$key} = $current ? $current + $element : $element;

        push $by_end_pos{ $item->end_pos }->@*,     $item;
        push $by_start_pos{ $item->start_pos }->@*, $item;

        return $chart{$key};
    }

    method items_ending_at($end_pos) {
        return $by_end_pos{$end_pos}->@* if exists $by_end_pos{$end_pos};
        return;
    }

    method goal_value( $start_symbol, $n ) {
        # Find all complete items that span [0,n] with LHS = start_symbol
        my $result = $semiring->add_id;

        for my $item ($self->items_ending_at($n)) {
            next unless $item->is_complete;
            next unless $item->start_pos == 0;
            next unless $item->rule->lhs eq $start_symbol;

            my $element = $self->get_element($item);
            $result = $result + $element if $element;
        }

        # Check if we found any valid parses
        return $result == $semiring->add_id ? undef : $result;
    }
}

class Parser {
    field $semiring :param = ViterbiSemiring->new();
    field $grammar :param;

    method parse(@input) {
        my $n = scalar @input;

        my $chart = EarleyChart->new( semiring => $semiring, );

        # Initialize chart by predicting all rules for start symbol at position 0
        for my $rule ($grammar->rules_for($grammar->start_symbol)) {
            my $start_item = EarleyItem->new(
                start_pos => 0,
                rule      => $rule,
                dot_pos   => 0,
                end_pos   => 0,
            );

            my $start_element = $semiring->init_element_from_rule($rule);
            $chart->add_element($start_item, $start_element);
        }

        for my $p ( 0 .. $n ) {
            $self->process_position( $p, $chart, \@input );
        }

        return $chart->goal_value( $grammar->start_symbol, $n );
    }

    method process_position( $pos, $chart, $input ) {
        my @agenda = $chart->items_ending_at($pos);

        while ( my $item = shift @agenda ) {
            my $element = $chart->get_element($item);

            if ( $item->is_complete ) {
                $self->complete( $item, $element, $chart, \@agenda );
            }
            elsif ( my $next_sym = $item->next_symbol ) {
                if ( $grammar->is_nonterminal($next_sym) ) {
                    $self->predict( $item, $next_sym, $chart, \@agenda );
                }
                elsif ( $pos < @$input && $next_sym eq $input->[$pos] ) {
                    $self->scan( $item, $element, $chart, $pos );
                }
            }
        }
    }

    method complete( $completed_item, $completed_element, $chart, $agenda ) {
        my $lhs     = $completed_item->rule->lhs;
        my @waiting = $chart->items_ending_at( $completed_item->start_pos );

    # Find items waiting for this nonterminal at the completion's start position
        for my $waiting_item (@waiting) {
            next if $waiting_item->is_complete;
            next unless ( $waiting_item->next_symbol // '' ) eq $lhs;

            my $waiting_element = $chart->get_element($waiting_item);

            # Semiring multiplication ⊗ combines sequential components
            my $combined_element = $waiting_element * $completed_element;

            my $new_item = EarleyItem->new(
                start_pos => $waiting_item->start_pos,
                rule      => $waiting_item->rule,
                dot_pos   => $waiting_item->dot_pos + 1,
                end_pos   => $completed_item->end_pos
            );

            $chart->add_element( $new_item, $combined_element );
            push @$agenda, $new_item;
        }
    }

    method predict( $item, $nonterminal, $chart, $agenda ) {
        for my $rule ( $grammar->rules_for($nonterminal) ) {
            my $predicted_item = EarleyItem->new(
                start_pos => $item->end_pos,
                rule      => $rule,
                dot_pos   => 0,
                end_pos   => $item->end_pos
            );

            next if $chart->get_element($predicted_item);

            my $rule_element = $semiring->init_element_from_rule($rule);
            $chart->add_element( $predicted_item, $rule_element );
            push @$agenda, $predicted_item;
        }
    }

    method scan( $item, $element, $chart, $pos ) {
        my $scanned_item = EarleyItem->new(
            start_pos => $item->start_pos,
            rule      => $item->rule,
            dot_pos   => $item->dot_pos + 1,
            end_pos   => $pos + 1
        );

        $chart->add_element( $scanned_item, $element );
    }
}

class GrammarRule {
    use overload '""' => 'to_string';
    use Digest::SHA qw(sha1_hex);

    field $lhs :param :reader;
    field $rhs :param :reader;
    field $probability :param :reader = 1.0;

    field $id :reader = sha1_hex( $lhs, $rhs->@* );

    method to_string(@) {
        my $short_id = substr( $id, 0, 8 );
        return "($short_id) $lhs -> " . join ' ', $rhs->@*;
    }
}

class Grammar {
    field $rules        :param :reader;
    field $start_symbol :param :reader;

    my sub new_rule( $lhs, $rhs ) {
        return GrammarRule->new( lhs => $lhs, rhs => $rhs );
    }

    sub build_grammar( $class, @rules ) {
        my %rules = ();
        for (@rules) {
            my $lhs = $_->[0];
            push @{ $rules{$lhs} //= [] }, new_rule(@$_);
        }
        return Grammar->new( rules => \%rules, start_symbol => $rules[0]->[0] );
    }

    method start_rule() { return $rules->{$start_symbol}->[0] }

    method rules_for($symbol) {
        return $rules->{$symbol}->@* if exists $rules->{$symbol};
        return;
    }

    method is_nonterminal($symbol) {
        return exists $rules->{$symbol};
    }

    method to_string(@) {
        my $grammar = '';
        $grammar .= "Grammar:\n";
        for my $nt ( sort keys $rules->%* ) {
            for my $rule ( $rules->{$nt}->@* ) {
                $grammar .= "  $rule\n";
            }
        }
        $grammar .= "\n";
        return $grammar;
    }
}

