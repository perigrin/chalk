#!/usr/bin/env perl
use utf8;
binmode STDERR, ':utf8';

use v5.42;
use experimental 'class';

our %SYMBOL_TABLE;  # Global symbol table for variables

our sub DEBUG($msg) { $ENV{DEBUG} && say STDERR "DEBUG: $msg" }
# Base IRNode class
class IRNode {
    use List::Util qw(uniq);

    field $inputs :param = [];
    field $attributes :param = {};
    field $hash;  # Computed eagerly in ADJUST block
    field $outputs :param = [];  # Renamed from outputs, nodes that depend on this one
    field $value :reader :writer;           # Cached result value
    field $ready_count :reader = 0; # How many dependencies have completed
    field $total_deps :reader;      # Total number of dependencies needed

    ADJUST {
        use Digest::SHA qw(sha1_hex);
        $hash = sha1_hex($self->operation, %$attributes, map { $_->id } @$inputs);
    }

    method inputs() { @$inputs }
    method outputs() { @$outputs }

    method inc_ready_count() {
        $ready_count++;
        DEBUG ref($self) . "(" . $self->short_id . ") inc_ready_count: now " . $ready_count . "/" . ($total_deps || 0);
    }

    method input_at($index) { $inputs->[$index] }

    method attr($key) { $attributes->{$key} }

    # Each subclass implements its own execution logic
    method execute() { ... }
    method operation() { ... }

    method id() { $hash }
    method short_id() { substr($hash, 0, 8) }

    method to_string() { $self->operation(). "(".$self->short_id().")" }

    method DESTROY() {
        DEBUG "DESTROYING " . ref($self) . "(" . substr($hash, 0, 8) . ")";
    }
}

# Specific operation node types
class ConstantNode :isa(IRNode) {
    method operation() { "Constant" }

    method execute() {
        $self->set_value($self->attr('value'));
    }
}

class AddNode :isa(IRNode) {
    method operation() { "Add" }

    method execute() {
        my $left = $self->input_at(0)->value();
        my $right = $self->input_at(1)->value();
        $self->set_value($left + $right);
    }
}

class PrintNode :isa(IRNode) {

    method operation() { "Print" }

    method execute() {
        my $input_val = $self->input_at(0)->value();
        DEBUG "PrintNode executing with value: " . ($input_val // 'undef');
        print $input_val // '';
        $self->set_value($input_val);  # Print passes through its input
    }
}

class StoreNode :isa(IRNode) {
    method operation() { "Store" }

    method execute() {
        my $var_name = $self->attr('var');
        my $stored_value = $self->input_at(0)->value();
        DEBUG "StoreNode($var_name) storing value: '$stored_value'";
        $SYMBOL_TABLE{$var_name} = $stored_value;
        $self->set_value($stored_value);
    }
}

class LoadNode :isa(IRNode) {
    method operation() { "Load" }

    method execute() {
        my $var_name = $self->attr('var');
        my $version = $self->attr('version');

        # Note: Check for undefined variables (version 0 with no inputs) happens in peephole optimizer
        # after orphan cleanup, not during execution

        my $value = $SYMBOL_TABLE{$var_name};
        DEBUG "LoadNode($var_name) executing: symbol_table has " . (defined $value ? "'$value'" : 'undef');
        $self->set_value($value);
    }
}

class ConcatNode :isa(IRNode) {
    method operation() { "Concat" }

    method execute() {
        my $result = "";
        my @inputs = $self->inputs;
        DEBUG "ConcatNode executing with " . scalar(@inputs) . " inputs";
        for my $input (@inputs) {
            my $val = $input->value() // '';
            DEBUG "  Input: " . ref($input) . " value: '$val'";
            $result .= $val;
        }
        DEBUG "ConcatNode result: '$result'";
        $self->set_value($result);
    }
}

class ComparisonNode :isa(IRNode) {
    method operation() { "Comparison" }

    method execute() {
        my $left = $self->input_at(0)->value();
        my $right = $self->input_at(1)->value();
        my $op = $self->attr('op');

        DEBUG "ComparisonNode executing: '$left' $op '$right'";

        my $result;
        if ($op eq 'eq') {
            $result = ($left // '') eq ($right // '') ? 1 : 0;
        } elsif ($op eq 'ne') {
            $result = ($left // '') ne ($right // '') ? 1 : 0;
        } elsif ($op eq '==') {
            $result = $self->to_number($left) == $self->to_number($right) ? 1 : 0;
        } elsif ($op eq '!=') {
            $result = $self->to_number($left) != $self->to_number($right) ? 1 : 0;
        } elsif ($op eq '<') {
            $result = $self->to_number($left) < $self->to_number($right) ? 1 : 0;
        } elsif ($op eq '>') {
            $result = $self->to_number($left) > $self->to_number($right) ? 1 : 0;
        } elsif ($op eq '<=') {
            $result = $self->to_number($left) <= $self->to_number($right) ? 1 : 0;
        } elsif ($op eq '>=') {
            $result = $self->to_number($left) >= $self->to_number($right) ? 1 : 0;
        } else {
            die "Unknown comparison operator: $op";
        }

        DEBUG "ComparisonNode result: $result";
        $self->set_value($result);
    }

    method to_number($val) {
        return 0 + $val;
    }
}

class LogicalAndNode :isa(IRNode) {
    method operation() { "LogicalAnd" }

    method execute() {
        my $left = $self->input_at(0)->value();

        DEBUG "LogicalAndNode executing with left: '$left'";

        # Short-circuit evaluation: if left is false, don't evaluate right
        unless ($self->is_true($left)) {
            DEBUG "LogicalAndNode short-circuit: left is false, returning 0";
            $self->set_value(0);
            return;
        }

        # Left is true, evaluate right
        my $right = $self->input_at(1)->value();
        DEBUG "LogicalAndNode right value: '$right'";

        my $result = $self->is_true($right) ? 1 : 0;
        DEBUG "LogicalAndNode result: $result";
        $self->set_value($result);
    }

    method is_true($val) {
        return !!$val;
    }
}

class LogicalOrNode :isa(IRNode) {
    method operation() { "LogicalOr" }

    method execute() {
        my $left = $self->input_at(0)->value();

        DEBUG "LogicalOrNode executing with left: '$left'";

        # Short-circuit evaluation: if left is true, don't evaluate right
        if ($self->is_true($left)) {
            DEBUG "LogicalOrNode short-circuit: left is true, returning 1";
            $self->set_value(1);
            return;
        }

        # Left is false, evaluate right
        my $right = $self->input_at(1)->value();
        DEBUG "LogicalOrNode right value: '$right'";

        my $result = $self->is_true($right) ? 1 : 0;
        DEBUG "LogicalOrNode result: $result";
        $self->set_value($result);
    }

    method is_true($val) {
        return !!$val;
    }
}

class NotNode :isa(IRNode) {
    method operation() { "Not" }

    method execute() {
        my $input = $self->input_at(0)->value();

        DEBUG "NotNode executing with input: '$input'";

        my $result = $self->is_true($input) ? 0 : 1;
        DEBUG "NotNode result: $result";
        $self->set_value($result);
    }

    method is_true($val) {
        return !!$val;
    }
}

class ThreadedSeaOfNodes {
    field %nodes;           # Hash of nodes by their content hash
    field $entry_node;
    field %symbol_versions; # Track SSA versions: $symbol_versions{var} = current_version

    method set_entry_node($node) {
        $entry_node = $node;
        DEBUG "Entry node set to: " . (defined $node ? $node->to_string : 'undef');
    }

    method mark_orphaned($node) {
        # Remove the node from the nodes hash if it exists
        my $hash = $node->id();
        if (exists $nodes{$hash}) {
            DEBUG "Marking node as orphaned: " . $node->to_string;
            delete $nodes{$hash};
        }
    }

    method add_node($node) {
        my $hash_key = $node->id();
        DEBUG "add_node: " . ref($node) . " with hash = $hash_key";

        if (exists $nodes{$hash_key}) {
            DEBUG "add_node: returning existing node";
            return $nodes{$hash_key};
        }

        $nodes{$hash_key} = $node;
        DEBUG "add_node: stored new " . ref($node) . " in nodes hash";
        DEBUG "add_node: nodes hash now has " . scalar(keys %nodes) . " entries";
        return $node;
    }


    method find_store_node($var_name, $version) {
        for my $node ($self->nodes) {
            next unless $node->isa('StoreNode');
            next unless $node->attr('var') eq $var_name;
            next unless $node->attr('version') == $version;
            return $node;
        }
        return;
    }



    method nodes() { values %nodes }
    method node_count() { scalar keys %nodes }

    method get_symbol_version($var_name) { $symbol_versions{$var_name} // 0 }
    method set_symbol_version($var_name, $version) { $symbol_versions{$var_name} = $version }
    method increment_symbol_version($var_name) {
        $symbol_versions{$var_name} = ($symbol_versions{$var_name} // 0) + 1;
        return $symbol_versions{$var_name};
    }

    method try_execute_node($node_hash, $dependents_map = undef) {
      DEBUG "try_execute_node called with hash: $node_hash";
      my $node = $nodes{$node_hash};
      unless ($node) {
          DEBUG "  Node not found in nodes hash!";
          DEBUG "  Available hashes: " . join(", ", map { substr($_, 0, 8) } sort keys %nodes);
          return;
      }

      my @inputs = $node->inputs;
      DEBUG "  Found node: " . ref($node) . " with " . scalar(@inputs) . " inputs";

      # Check if all inputs have computed values (are ready)
      for my $i (0 .. $#inputs) {
          my $input = $inputs[$i];
          unless (defined $input->value) {
              DEBUG "  Input $i (" . ref($input) . ") not ready yet";
              return;
          }
          DEBUG "  Input $i (" . ref($input) . ") has value: '" . ($input->value // 'undef') . "'";
      }

      DEBUG "  All inputs ready - executing node!";
      $node->execute();
      $self->notify_dependents($node_hash, $dependents_map);
   }

   method notify_dependents($node_hash, $dependents_map = undef) {
       my $node = $nodes{$node_hash} or return;
       DEBUG "notify_dependents called for " . ref($node) . "(" . $node->short_id . ")";

       my @dependent_hashes =  @{$dependents_map->{$node_hash} || []};

       DEBUG "  has " . scalar(@dependent_hashes) . " dependent entries";

       # Notify each dependent once per dependency relationship
       # This allows nodes with same input multiple times to get multiple notifications
       for my $dependent_hash (@dependent_hashes) {
           DEBUG "  notifying dependent: $dependent_hash";
           $self->try_execute_node($dependent_hash, $dependents_map);
       }
   }

   method execute_threaded() {
       # Link up LoadNodes to StoreNodes after parsing is complete
       $self->link_load_nodes();

       # Run peephole optimizations first
       $self->run_peephole_optimizations();

       # Clean up unreferenced nodes BEFORE building dependency graph
       $self->cleanup_orphaned_nodes();

       # Build dependency graph for execution (after cleanup)
       my $dependents_map = $self->build_dependency_graph();

       my @leaf_nodes = grep { scalar($_->inputs) == 0 } $self->nodes;
       DEBUG "Found " . scalar(@leaf_nodes) . " leaf nodes";
       DEBUG "Nodes after cleanup: " . scalar($self->nodes) . " total";
       for my $node ($self->nodes) {
           DEBUG "  " . $node->to_string . " (inputs: " . scalar($node->inputs) . ")";
       }

       for my $leaf (@leaf_nodes) {
           my $type = ref($leaf);
           my $extra = "";
           if ($leaf->isa('StoreNode') || $leaf->isa('LoadNode')) {
               $extra = " var=" . ($leaf->attr('var') // 'unknown');
           }
           DEBUG "Trying to execute leaf node: $type$extra (" . $leaf->id(). ")";
           $self->try_execute_node($leaf->id(), $dependents_map);
       }
   }

   method dump_graph() {
       say "Generated Sea of Nodes with " . $self->node_count . " nodes";

       # Debug: show the generated nodes
       my @nodes = $self->nodes;
       for my $node (@nodes) {
           my $class_name = ref($node);
           $class_name =~ s/.*:://;  # Remove package prefix
           say $node->to_string;

           if ($node->operation eq 'Constant') {
               say "  Value: '" . ($node->attr('value') // 'undef') . "'";
           } elsif ($node->operation eq 'Store' || $node->operation eq 'Load') {
               say "  Variable: " . ($node->attr('var') // 'undef') .
                   " v" . ($node->attr('version') // 'undef');
           }

           if ($node->inputs) {
               say "  Inputs: " . join(', ', map { $_->to_string } $node->inputs);
           }
       }

       say "\n=== Dependency Graph ===";
       for my $node (@nodes) {
           my $short_id = $node->short_id;
           my @inputs = $node->inputs;
           if (@inputs) {
               for my $input (@inputs) {
                   say ref($input) . " " . $input->short_id . " -> " . ref($node) . " " . $short_id;
               }
           } else {
               say ref($node) . " " . $short_id . " (leaf node)";
           }
       }
   }

   method link_waiting_load_nodes($var_name, $store_node) {
       DEBUG "Linking LoadNodes waiting for \$$var_name to StoreNode";

       # Collect LoadNodes that need linking to this specific variable
       my @waiting_loads = grep {
           $_->isa('LoadNode') &&
           !$_->inputs &&
           $_->attr('var') eq $var_name
       } $self->nodes;

       for my $old_load (@waiting_loads) {
           DEBUG "Linking LoadNode(\$$var_name) to StoreNode";

           # Create new LoadNode with input
           my $new_load = LoadNode->new(
               attributes => {
                   var => $old_load->attr('var'),
                   version => $old_load->attr('version')
               },
               inputs => [$store_node]
           );

           # Replace the old LoadNode with the new one
           $self->replace_node($old_load, $new_load);
       }
   }

   method link_load_nodes() {
       DEBUG "Linking LoadNodes to StoreNodes after parsing";

       # Debug: show all StoreNodes
       DEBUG "Available StoreNodes:";
       for my $node ($self->nodes) {
           if ($node->isa('StoreNode')) {
               DEBUG "  StoreNode: var=" . $node->attr('var') . " version=" . $node->attr('version');
           }
       }

       # Collect LoadNodes that need linking
       my @unlinked_loads = grep { $_->isa('LoadNode') && !$_->inputs } $self->nodes;

       for my $old_load (@unlinked_loads) {
           my $var_name = $old_load->attr('var');
           my $version = $old_load->attr('version');

           # Try to find matching StoreNode
           if (my $store_node = $self->find_store_node($var_name, $version)) {
               DEBUG "Deferred linking: LoadNode($var_name) -> StoreNode version $version";

               # Create new LoadNode with input
               my $new_load = LoadNode->new(
                   attributes => {
                       var => $var_name,
                       version => $version
                   },
                   inputs => [$store_node]
               );

               # Replace the old LoadNode with the new one
               $self->replace_node($old_load, $new_load);
           } else {
               DEBUG "Deferred linking: No StoreNode found for LoadNode($var_name) version $version";
           }
       }
   }

   method run_peephole_optimizations() {
       DEBUG "Running peephole optimizations";

       # Parse selection patterns (run first to resolve ambiguities)
       $self->resolve_operator_precedence();
       $self->prefer_longer_expressions();

       # Traditional peephole optimizations
       # Find all ConstantNodes marked for interpolation
       for my $node ($self->nodes) {
           next unless $node->isa('ConstantNode');
           next unless $node->attr('needs_interpolation');

           my $content = $node->attr('value');
           DEBUG "Checking for interpolation in: $content";

           # Look for $identifier patterns
           if ($content =~ /\$(\w+)/) {
               DEBUG "Found variable interpolation: \$$1";
               $self->replace_with_interpolation($node, $content);
           }
       }

       # TODO: Implement proper undefined variable checking
       # Currently disabled to allow multi-statement programs to work
       # The issue is complex interaction between parsing order, execution order, and orphan cleanup
   }

   method replace_with_interpolation($const_node, $content) {
       my @parts;
       my $pos = 0;

       # Parse the string looking for $identifier patterns
       while ($content =~ /\G(.*?)\$(\w+)/gc) {
           my ($prefix, $var_name) = ($1, $2);

           # Add literal text before the variable
           if (length($prefix) > 0) {
               push @parts, $self->add_node(ConstantNode->new(attributes => {value => $prefix}));
           }

           # Add variable load - find the corresponding StoreNode
           my $version = $self->get_symbol_version($var_name) || 1;
           my $store_node = $self->find_store_node($var_name, $version);

           my $load_node;
           if ($store_node) {
               # Create LoadNode with StoreNode as input
               $load_node = $self->add_node(LoadNode->new(
                   attributes => {var => $var_name, version => $version},
                   inputs => [$store_node]
               ));
               DEBUG "Created LoadNode for $var_name with StoreNode dependency";
           } else {
               # Fallback: create unlinked LoadNode (will be linked later)
               $load_node = $self->add_node(LoadNode->new(
                   attributes => {var => $var_name, version => $version}
               ));
               DEBUG "Created unlinked LoadNode for $var_name - will link later";
           }
           push @parts, $load_node;
           DEBUG "Added interpolation for variable: $var_name";
       }

       # Add any remaining literal text
       if ($content =~ /\G(.+)$/gc) {
           push @parts, $self->add_node(ConstantNode->new(attributes => {value => $1}));
       }

       # If we have multiple parts, create a concat node
       if (@parts > 1) {
           my $concat_node = $self->add_node(ConcatNode->new(inputs => [@parts]));

           # Update all references to the old constant node
           $self->replace_node($const_node, $concat_node);
       }
   }


   method remove_if_orphaned($node) {
       my $hash = $node->id;

       DEBUG "Checking if node is orphaned: " . $node->to_string;

       return unless exists $nodes{$hash};  # Already removed
       return if defined $entry_node && $node == $entry_node;  # Can't orphan entry node

       # Never orphan PrintNodes - they represent program output
       return if $node->isa('PrintNode');

       # Check if any node in the graph still references this one as input
       for my $other_node ($self->nodes) {
           for my $input ($other_node->inputs) {
               if ($input == $node) {
                   DEBUG "  Node still referenced by: " . $other_node->to_string;
                   return;  # Still referenced, not orphaned
               }
           }
       }

       # Not referenced by anyone, safe to remove
       DEBUG "Removing orphaned node: " . $node->to_string . " (hash: $hash)";
       delete $nodes{$hash};
       return 1;  # Was orphaned and removed
   }

   method build_dependency_graph() {
       DEBUG "Building dependency graph (outputs/dependents)";

       my %dependents_map;  # hash -> [array of dependent hashes]

       # For each node, find all nodes that depend on it (have it as input)
       for my $node ($self->nodes) {
           my $node_hash = $node->id;
           my @dependents;

           # Look through all other nodes to see which ones have this node as input
           for my $other_node ($self->nodes) {
               next if $other_node == $node;  # Skip self

               for my $input ($other_node->inputs) {
                   if ($input == $node) {
                       push @dependents, $other_node->id;
                       last;  # This other_node depends on current node
                   }
               }
           }

           $dependents_map{$node_hash} = \@dependents;

           if (@dependents) {
               DEBUG "Node " . $node->to_string . " has " . scalar(@dependents) . " dependents";
           }
       }

       return \%dependents_map;
   }

   method replace_node($old_node, $new_node) {
       my $old_hash = $old_node->id();
       my $new_hash = $new_node->id();

       DEBUG "replace_node: $old_hash -> $new_hash";

       # Replace in nodes hash
       if (exists $nodes{$old_hash}) {
           delete $nodes{$old_hash};
           $nodes{$new_hash} = $new_node;
           DEBUG "  Updated nodes hash";
       } else {
           DEBUG "  Warning: old_hash $old_hash not found in nodes hash";
       }

       # Find all nodes that use the old node as input and replace them
       my @nodes_to_replace;
       for my $node ($self->nodes) {
           my @inputs = $node->inputs;
           for (my $i = 0; $i < @inputs; $i++) {
               if ($inputs[$i] == $old_node) {
                   DEBUG "  Node " . $node->to_string . " uses old node as input $i";

                   # Create replacement inputs array
                   my @new_inputs = @inputs;
                   $new_inputs[$i] = $new_node;

                   # Create new version of this node
                   my $replacement_node = $self->create_node_with_inputs($node, @new_inputs);
                   if ($replacement_node) {
                       push @nodes_to_replace, [$node, $replacement_node];
                   }
               }
           }
       }

       # Recursively replace all nodes that referenced the old node
       for my $pair (@nodes_to_replace) {
           my ($old_referring_node, $new_referring_node) = @$pair;
           $self->replace_node($old_referring_node, $new_referring_node);
       }
   }

   method create_node_with_inputs($original_node, @new_inputs) {
       # Create a new node of the same type but with different inputs
       my $class = ref($original_node);

       if ($class eq 'PrintNode') {
           return $self->add_node(PrintNode->new(inputs => [@new_inputs]));
       } elsif ($class eq 'AddNode') {
           return $self->add_node(AddNode->new(inputs => [@new_inputs]));
       } elsif ($class eq 'ConcatNode') {
           return $self->add_node(ConcatNode->new(inputs => [@new_inputs]));
       } elsif ($class eq 'StoreNode') {
           my $var = $original_node->attr('var');
           my $version = $original_node->attr('version');
           return $self->add_node(StoreNode->new(
               attributes => {var => $var, version => $version},
               inputs => [@new_inputs]
           ));
       } elsif ($class eq 'ComparisonNode') {
           my $op = $original_node->attr('op');
           return $self->add_node(ComparisonNode->new(
               attributes => {op => $op},
               inputs => [@new_inputs]
           ));
       } elsif ($class eq 'LogicalAndNode') {
           return $self->add_node(LogicalAndNode->new(inputs => [@new_inputs]));
       } elsif ($class eq 'LogicalOrNode') {
           return $self->add_node(LogicalOrNode->new(inputs => [@new_inputs]));
       } elsif ($class eq 'NotNode') {
           return $self->add_node(NotNode->new(inputs => [@new_inputs]));
       } elsif ($class eq 'LoadNode') {
           my $var = $original_node->attr('var');
           my $version = $original_node->attr('version');
           return $self->add_node(LoadNode->new(
               attributes => {var => $var, version => $version},
               inputs => [@new_inputs]
           ));
       } elsif ($class eq 'ConstantNode') {
           # ConstantNodes don't have inputs, so no replacement needed
           return undef;
       }

       DEBUG "Warning: Unknown node type for replacement: $class";
       return undef;
   }

    method cleanup_orphaned_nodes() {
       DEBUG "Cleaning up orphaned nodes";
       my $before_count = scalar keys %nodes;

       # Get a snapshot of all nodes to check (since we'll be modifying %nodes during iteration)
       my @all_nodes = $self->nodes;
       my $removed_count = 0;

       for my $node (@all_nodes) {
           if ($self->remove_if_orphaned($node)) {
               $removed_count++;
           }
       }

       my $after_count = scalar keys %nodes;
       DEBUG "Cleaned up $removed_count orphaned nodes ($before_count -> $after_count)";
   }

   # Parse selection peephole patterns
   method resolve_operator_precedence() {
       DEBUG "Resolving operator precedence ambiguities";

       # Look for competing operator interpretations
       for my $node ($self->nodes) {
           if ($node->isa('PrintNode')) {
               $self->check_print_precedence($node);
           }
           if ($node->isa('ComparisonNode')) {
               $self->check_comparison_precedence($node);
           }
       }
   }

   method check_print_precedence($print_node) {
       my @inputs = $print_node->inputs;
       return unless @inputs;
       my $expr_input = $inputs[0];

       # Check if there are competing longer expressions for this print
       for my $node ($self->nodes) {
           if ($node->isa('LogicalOrNode') || $node->isa('LogicalAndNode')) {
               # If this operator could extend the print's expression
               if ($self->could_extend_expression($expr_input, $node)) {
                   DEBUG "Found precedence conflict: PrintNode vs " . ref($node);
                   $self->prefer_longer_expression($print_node, $node);
               }
           }
       }
   }

   method could_extend_expression($short_expr, $longer_expr) {
       # Check if the longer expression contains the shorter one as a component
       my @inputs = $longer_expr->inputs;
       for my $input (@inputs) {
           if ($input == $short_expr) {
               return 1;
           }
       }
       return 0;
   }

   method prefer_longer_expression($short_node, $long_node) {
       DEBUG "Preferring longer expression over shorter parse";
       # For now, we'll orphan competing PrintNodes that have shorter expressions
       # when there's a longer logical expression available
       $self->mark_node_as_orphaned($short_node);
   }

   method mark_node_as_orphaned($node) {
       # Remove from nodes hash - this will make it unreachable during cleanup
       my $hash = $node->id();
       if (exists $nodes{$hash}) {
           DEBUG "Marking node as orphaned: " . ref($node) . "($hash)";
           delete $nodes{$hash};
       }
   }

   method check_comparison_precedence($comparison_node) {
       # Comparison operators have higher precedence than logical operators
       # So ComparisonNode should be preferred over LogicalAnd/Or that would consume its operands

       for my $node ($self->nodes) {
           if ($node->isa('LogicalOrNode') || $node->isa('LogicalAndNode')) {
               # Check if logical operator is trying to split up a comparison
               if ($self->logical_splits_comparison($node, $comparison_node)) {
                   DEBUG "Found precedence conflict: " . ref($node) . " vs ComparisonNode";
                   DEBUG "Comparison has higher precedence - preferring ComparisonNode";
                   $self->prefer_comparison_over_logical($comparison_node, $node);
               }
           }
       }
   }

   method logical_splits_comparison($logical_node, $comparison_node) {
       # Check if the logical operator uses operands that should belong to the comparison
       my @logical_inputs = $logical_node->inputs;
       my @comparison_inputs = $comparison_node->inputs;

       # If logical operator shares an operand with comparison, there might be a precedence issue
       for my $logical_input (@logical_inputs) {
           for my $comparison_input (@comparison_inputs) {
               if ($logical_input == $comparison_input) {
                   return 1;
               }
           }
       }
       return 0;
   }

   method prefer_comparison_over_logical($comparison_node, $logical_node) {
       DEBUG "Preferring comparison precedence over logical operator";
       # Mark the logical node as orphaned since comparison should bind tighter
       $self->mark_node_as_orphaned($logical_node);
   }

   method prefer_longer_expressions() {
       DEBUG "Applying general preference for longer expressions";
       # This could implement more general patterns for preferring
       # longer over shorter expression interpretations
   }
}

# Grammar rule with semantic action
class GrammarRule {
    use experimental 'keyword_any';
    use Digest::SHA qw(sha1_hex);
    use Scalar::Util qw(refaddr);

    field $lhs :param :reader;          # Left-hand side nonterminal
    field $rhs :param :reader;          # Right-hand side symbols
    field $semantic_action :param;  # Code reference for building IR
    field $id :reader = sha1_hex($lhs, @$rhs, refaddr($semantic_action));

    method matches($symbols) {
        for my $s (@$symbols) {
            return 0 unless any { $s eq $_ } @$rhs;
        }
        return 1;
    }

    method rhs_length() { scalar @$rhs }
    method rhs_at($pos) { $rhs->[$pos] }

    method execute_action($matches, $ir_graph) {
        return $semantic_action->($matches, $ir_graph);
    }

    method to_string() {
        return $lhs . " → " . join(' ', @$rhs);
    }
}

# Earley item
class EarleyItem {
    use Digest::SHA qw(sha1_hex);

    field $rule :param :reader;
    field $dot_pos :param :reader = 0;
    field $start_pos :param :reader = 0;
    field $current_pos :param :reader :writer = 0;
    field $matched_text :param :reader :writer = "";
    field $semantic_value :param :reader = undef;
    field $id :reader = sha1_hex($rule->id, $dot_pos, $start_pos);

    method set_semantic_value($value) {
        $semantic_value = $value;
    }

    method is_complete() { $dot_pos >= $rule->rhs_length }
    method next_symbol() {
        return undef if $self->is_complete;
        return $rule->rhs_at($dot_pos);
    }

    method advance($matched_char = "") {
        DEBUG "Advancing item: " . $self->to_string;
        EarleyItem->new(
            rule => $rule,
            dot_pos => $dot_pos + 1,
            start_pos => $start_pos,
            current_pos => $current_pos,
            matched_text => $matched_text . $matched_char,
        );
    }

    method to_string() {
      my @rhs = $rule->rhs->@*;
      my @parts;
      for my $i (0 .. @rhs) {
          if ($i == $dot_pos) {
              push @parts, "•";
          }
          if ($i < @rhs) {
              push @parts, $rhs[$i];
          }
      }
      return $rule->lhs . " → " . join(' ', @parts);
    }
}

class ScanlessEarleyParser {
    field @grammar_rules;
    field $ir_graph = ThreadedSeaOfNodes->new();
    field @chart;  # Array of state sets
    field $input_text;
    field %nonterminals;
    field %left_recursive_rules;

    ADJUST {
        $self->define_grammar();
    }

    method define_grammar() {
        @grammar_rules = (
            # Program → StatementSeq
            GrammarRule->new(
                lhs => 'Program',
                rhs => ['StatementSeq'],
                semantic_action => sub ($matches, $ir) {
                    return $matches->[0];
                }
            ),


            # StatementSeq → Statement
            GrammarRule->new(
                lhs => 'StatementSeq',
                rhs => ['Statement'],
                semantic_action => sub ($matches, $ir) {
                    return $matches->[0];
                }
            ),

            # StatementSeq → Statement ';' WS StatementSeq
            GrammarRule->new(
                lhs => 'StatementSeq',
                rhs => ['Statement', ';', 'WS', 'StatementSeq'],
                semantic_action => sub ($matches, $ir) {
                    # Sequential composition - return the last statement
                    return $matches->[3];
                }
            ),


            # Statement → Expression | Assignment
            GrammarRule->new(
                lhs => 'Statement',
                rhs => ['Expression'],
                semantic_action => sub ($matches, $ir) {
                    return $matches->[0];
                }
            ),
            GrammarRule->new(
                lhs => 'Statement',
                rhs => ['Assignment'],
                semantic_action => sub ($matches, $ir) {
                    return $matches->[0];
                }
            ),

            # ComparisonOp → 'eq'
            GrammarRule->new(
                lhs => 'ComparisonOp',
                rhs => ['eq'],
                semantic_action => sub ($matches, $ir) {
                    return { op => 'eq' };
                }
            ),

            # ComparisonOp → 'ne'
            GrammarRule->new(
                lhs => 'ComparisonOp',
                rhs => ['ne'],
                semantic_action => sub ($matches, $ir) {
                    return { op => 'ne' };
                }
            ),

            # ComparisonOp → '=='
            GrammarRule->new(
                lhs => 'ComparisonOp',
                rhs => ['=='],
                semantic_action => sub ($matches, $ir) {
                    return { op => '==' };
                }
            ),

            # ComparisonOp → '!='
            GrammarRule->new(
                lhs => 'ComparisonOp',
                rhs => ['!='],
                semantic_action => sub ($matches, $ir) {
                    return { op => '!=' };
                }
            ),

            # Operator definitions (matching Guacamole)
            # OpLogOr → '||' | '//'
            GrammarRule->new(
                lhs => 'OpLogOr',
                rhs => ['||'],
                semantic_action => sub ($matches, $ir) {
                    return { op => '||' };
                }
            ),
            GrammarRule->new(
                lhs => 'OpLogOr',
                rhs => ['//'],
                semantic_action => sub ($matches, $ir) {
                    return { op => '//' };
                }
            ),

            # OpLogAnd → '&&'
            GrammarRule->new(
                lhs => 'OpLogAnd',
                rhs => ['&&'],
                semantic_action => sub ($matches, $ir) {
                    return { op => '&&' };
                }
            ),

            # Hierarchical precedence structure like Guacamole
            # Expression → LogicalOrExpr (top level)
            GrammarRule->new(
                lhs => 'Expression',
                rhs => ['LogicalOrExpr'],
                semantic_action => sub ($matches, $ir) {
                    return $matches->[0];
                }
            ),

            # LogicalOrExpr → LogicalOrExpr OpLogOr LogicalAndExpr | LogicalAndExpr (matching Guacamole ExprLogOr0)
            GrammarRule->new(
                lhs => 'LogicalOrExpr',
                rhs => ['LogicalOrExpr', 'WS', 'OpLogOr', 'WS', 'LogicalAndExpr'],
                semantic_action => sub ($matches, $ir) {
                    # $matches->[2] contains the operator info from OpLogOr
                    return $ir->add_node(LogicalOrNode->new(inputs => [$matches->[0], $matches->[4]]));
                }
            ),
            GrammarRule->new(
                lhs => 'LogicalOrExpr',
                rhs => ['LogicalAndExpr'],
                semantic_action => sub ($matches, $ir) {
                    return $matches->[0];
                }
            ),

            # LogicalAndExpr → LogicalAndExpr OpLogAnd ComparisonExpr | ComparisonExpr (matching Guacamole ExprLogAnd0)
            GrammarRule->new(
                lhs => 'LogicalAndExpr',
                rhs => ['LogicalAndExpr', 'WS', 'OpLogAnd', 'WS', 'ComparisonExpr'],
                semantic_action => sub ($matches, $ir) {
                    # $matches->[2] contains the operator info from OpLogAnd
                    return $ir->add_node(LogicalAndNode->new(inputs => [$matches->[0], $matches->[4]]));
                }
            ),
            GrammarRule->new(
                lhs => 'LogicalAndExpr',
                rhs => ['ComparisonExpr'],
                semantic_action => sub ($matches, $ir) {
                    return $matches->[0];
                }
            ),

            # ComparisonExpr → PrimaryExpr CompOp PrimaryExpr | PrimaryExpr
            GrammarRule->new(
                lhs => 'ComparisonExpr',
                rhs => ['PrimaryExpr', 'WS', 'ComparisonOp', 'WS', 'PrimaryExpr'],
                semantic_action => sub ($matches, $ir) {
                    return $ir->add_node(ComparisonNode->new(
                        attributes => {op => $matches->[2]->{op}},
                        inputs => [$matches->[0], $matches->[4]]
                    ));
                }
            ),
            GrammarRule->new(
                lhs => 'ComparisonExpr',
                rhs => ['PrimaryExpr'],
                semantic_action => sub ($matches, $ir) {
                    return $matches->[0];
                }
            ),

            # PrimaryExpr → Variable | StringLiteral | PrintExpr | '(' Expression ')'
            GrammarRule->new(
                lhs => 'PrimaryExpr',
                rhs => ['Variable'],
                semantic_action => sub ($matches, $ir) {
                    my $var_name = $matches->[0]{var_name};
                    my $version = $ir->get_symbol_version($var_name) || 1;
                    my $load_node = $ir->add_node(LoadNode->new(
                        attributes => {var => $var_name, version => $version}
                    ));
                    return $load_node;
                }
            ),
            GrammarRule->new(
                lhs => 'PrimaryExpr',
                rhs => ['StringLiteral'],
                semantic_action => sub ($matches, $ir) {
                    return $matches->[0];
                }
            ),
            GrammarRule->new(
                lhs => 'PrimaryExpr',
                rhs => ['PrintExpr'],
                semantic_action => sub ($matches, $ir) {
                    return $matches->[0];
                }
            ),
            GrammarRule->new(
                lhs => 'PrimaryExpr',
                rhs => ['(', 'WS', 'Expression', 'WS', ')'],
                semantic_action => sub ($matches, $ir) {
                    return $matches->[2];  # Return the inner Expression
                }
            ),

            # PrintExpr → 'print' WS Expression
            GrammarRule->new(
                lhs => 'PrintExpr',
                rhs => ['print', 'WS', 'Expression'],
                semantic_action => sub ($matches, $ir) {
                    my $expr_node = $matches->[2];
                    DEBUG "PrintExpr semantic action: expr_node = " . (defined $expr_node ? $expr_node->to_string : 'undef');
                    my $print_node = $ir->add_node(PrintNode->new(inputs => [$expr_node]));
                    DEBUG "PrintExpr semantic action: created print_node = " . (defined $print_node ? $print_node->to_string : 'undef');
                    return $print_node;
                }
            ),

            # Assignment → Variable WS '=' WS Expression
            GrammarRule->new(
                lhs => 'Assignment',
                rhs => ['Variable', 'WS', '=', 'WS', 'Expression'],
                semantic_action => sub ($matches, $ir) {
                    my $var_name = $matches->[0]{var_name};
                    my $expr_node = $matches->[4];
                    # Increment version for this variable
                    my $version = $ir->increment_symbol_version($var_name);

                    my $store_node = $ir->add_node(StoreNode->new(
                        attributes => {var => $var_name, version => $version},
                        inputs => [$expr_node]
                    ));
                    return $store_node;
                }
            ),

            # StringLiteral → '"' InterpolatedContent '"' (interpolated)
            GrammarRule->new(
                lhs => 'StringLiteral',
                rhs => ['"', 'InterpolatedContent', '"'],
                semantic_action => sub ($matches, $ir) {
                    my $node = $matches->[1];

                    # Process escape sequences for double-quoted strings
                    my $content = $node->attr('value');
                    $content =~ s/\\n/\n/g;   # newline
                    $content =~ s/\\t/\t/g;   # tab
                    $content =~ s/\\r/\r/g;   # carriage return
                    $content =~ s/\\\\/\\/g;  # backslash
                    $content =~ s/\\"/"/g;    # double quote
                    # Note: \$ should stay as \$ for now - the interpolation handler will deal with literal $
                    # Create new node with processed content using generic add_node
                    my $new_node = $ir->add_node(ConstantNode->new(
                        attributes => {value => $content, needs_interpolation => 1}
                    ));

                    DEBUG "StringLiteral: processed escapes and marking final string '" . $new_node->attr('value') . "' for interpolation";

                    return $new_node;
                }
            ),

            # StringLiteral → "'" StringContent "'"
            GrammarRule->new(
                lhs => 'StringLiteral',
                rhs => ["'", 'StringContent', "'"],
                semantic_action => sub ($matches, $ir) {
                    my $content = $matches->[1]{text};
                    my $const_node = $ir->add_node(ConstantNode->new(attributes => {value => $content}));
                    return $const_node;
                }
            ),

            # StringContent → CharSeq (for single-quoted strings)
            GrammarRule->new(
                lhs => 'StringContent',
                rhs => ['CharSeq'],
                semantic_action => sub ($matches, $ir) {
                    DEBUG "StringContent CharSeq: " . $matches->[0]{text};
                    return { text => $matches->[0]{text} };
                }
            ),

            # InterpolatedContent → CharSeq (same as StringContent but will be marked for interpolation)
            GrammarRule->new(
                lhs => 'InterpolatedContent',
                rhs => ['CharSeq'],
                semantic_action => sub ($matches, $ir) {
                    my $content = $matches->[0]{text};
                    DEBUG "InterpolatedContent semantic action called with: '$content'";
                    my $const_node = $ir->add_node(ConstantNode->new(attributes => {value => $content}));
                    # Don't mark for interpolation yet - let StringLiteral decide
                    # when it has the complete string
                    return $const_node;
                }
            ),

            # CharSeq → Char CharSeq
            GrammarRule->new(
                lhs => 'CharSeq',
                rhs => ['Char', 'CharSeq'],
                semantic_action => sub ($matches, $ir) {
                    DEBUG "CharSeq (recursive) semantic action: building '" . $matches->[0]{char} . "' + '" . ($matches->[1]{text} // '') . "'";
                    return { text => $matches->[0]{char} . $matches->[1]{text} // '' };
                }
            ),

            # CharSeq → Char
            GrammarRule->new(
                lhs => 'CharSeq',
                rhs => ['Char'],
                semantic_action => sub ($matches, $ir) {
                    return { text => $matches->[0]{char} };
                }
            ),

            # Variable → '$' Identifier
            GrammarRule->new(
                lhs => 'Variable',
                rhs => ['$', 'Identifier'],
                semantic_action => sub ($matches, $ir) {
                    return { var_name => $matches->[1]{name} };
                }
            ),

            # Identifier → Letter LetterDigitSeq
            GrammarRule->new(
                lhs => 'Identifier',
                rhs => ['Letter', 'LetterDigitSeq'],
                semantic_action => sub ($matches, $ir) {
                    return { name => $matches->[0]{char} . $matches->[1]{text} };
                }
            ),

            # Identifier → Letter
            GrammarRule->new(
                lhs => 'Identifier',
                rhs => ['Letter'],
                semantic_action => sub ($matches, $ir) {
                    return { name => $matches->[0]{char} };
                }
            ),

            # LetterDigitSeq → LetterDigit LetterDigitSeq
            GrammarRule->new(
                lhs => 'LetterDigitSeq',
                rhs => ['LetterDigit', 'LetterDigitSeq'],
                semantic_action => sub ($matches, $ir) {
                    return { text => $matches->[0]{char} . $matches->[1]{text} };
                }
            ),

            # LetterDigitSeq → LetterDigit
            GrammarRule->new(
                lhs => 'LetterDigitSeq',
                rhs => ['LetterDigit'],
                semantic_action => sub ($matches, $ir) {
                    return { text => $matches->[0]{char} };
                }
            ),

            # WS → Whitespace WS
            GrammarRule->new(
                lhs => 'WS',
                rhs => ['Whitespace', 'WS'],
                semantic_action => sub ($matches, $ir) {
                    return undef;  # Whitespace has no semantic value
                }
            ),

            # WS → Whitespace
            GrammarRule->new(
                lhs => 'WS',
                rhs => ['Whitespace'],
                semantic_action => sub ($matches, $ir) {
                    return undef;
                }
            ),

            # WS → ε (empty)
            GrammarRule->new(
                lhs => 'WS',
                rhs => [],
                semantic_action => sub ($matches, $ir) {
                    return undef;
                }
            ),

            # Handle comments as statements
            GrammarRule->new(
                lhs => 'Statement',
                rhs => ['Comment'],
                semantic_action => sub ($matches, $ir) {
                    return undef;  # Comments produce no semantic value
                }
            ),

            # Comment → '#' CommentText VerticalSpace
            GrammarRule->new(
                lhs => 'Comment',
                rhs => ['#', 'CommentText', 'VerticalSpace'],
                semantic_action => sub ($matches, $ir) {
                    return undef;
                }
            ),

            # CommentText → CommentCharSeq (like CharSeq but for comments)
            GrammarRule->new(
                lhs => 'CommentText',
                rhs => ['CommentCharSeq'],
                semantic_action => sub ($matches, $ir) {
                    return undef;  # Comments don't need to return text
                }
            ),

            # CommentCharSeq → CommentLineChar CommentCharSeq
            GrammarRule->new(
                lhs => 'CommentCharSeq',
                rhs => ['CommentLineChar', 'CommentCharSeq'],
                semantic_action => sub ($matches, $ir) {
                    return undef;  # Comments don't need to return text
                }
            ),

            # CommentCharSeq → CommentLineChar
            GrammarRule->new(
                lhs => 'CommentCharSeq',
                rhs => ['CommentLineChar'],
                semantic_action => sub ($matches, $ir) {
                    return undef;  # Comments don't need to return text
                }
            ),



        );

        %nonterminals = map { $_->lhs => $_ } @grammar_rules;

        # Detect left-recursive rules
        for my $rule (@grammar_rules) {
            if (@{$rule->rhs} > 0 && $rule->rhs->[0] eq $rule->lhs) {
                $left_recursive_rules{$rule->id} = 1;
                DEBUG "Detected left-recursive rule: " . $rule->to_string;
            }
        }
    }


    method parse($text) {
        $input_text = $text;
        @chart = ();
        my %seen_items;  # Track items by hash to prevent duplicates

        DEBUG "Parsing text: $text";
        # Initialize chart with start state - predict all Program rules
        $chart[0] = [
            map { EarleyItem->new( rule => $_ ) }
            grep { $_->lhs eq 'Program' } @grammar_rules
        ];

        # Mark initial items as seen
        for my $item (@{$chart[0]}) {
            $seen_items{$item->id()} = 1;
        }

        # Helper to add item only if not seen
        my $add_item = sub ($item, $chart_pos, $to_agenda) {
            my $item_hash = $item->id();
            if (!$seen_items{$item_hash}) {
                $seen_items{$item_hash} = 1;
                push @{$chart[$chart_pos]}, $item;
                push @$to_agenda, $item if $to_agenda;
                DEBUG "Added new item: " . $item->to_string;
                return 1;
            }
            DEBUG "Skipping duplicate item: " . $item->to_string;
            return 0;
        };

        # Main parsing loop - process each character position
        for my $pos (0 .. length($text)) {
            DEBUG "Processing position $pos";
            $chart[$pos] //= [];

            my $agenda = [@{$chart[$pos]}];
            DEBUG "Agenda: " . join(', ', map { $_->to_string } @$agenda);
            while (@$agenda) {
                my $item = shift @$agenda;

                if ($item->is_complete) {
                    DEBUG "Completed item: " . $item->to_string;
                    $self->complete($item, $pos, $agenda);
                } else {
                    my $next_sym = $item->next_symbol;
                    if ($self->is_character_class($next_sym)) {
                        $self->scan_character($item, $pos, $text);
                    } elsif ($self->is_nonterminal($next_sym)) {
                       $self->predict($item, $pos, $agenda);
                    } else {
                        $self->scan_literal($item, $pos, $text);
                    }
                }
            }
        }
        # After parsing is complete, find the final Program result and set it as entry_node
        my $final_pos = length($text);
        DEBUG "Looking for completed Program items at final position $final_pos";
        DEBUG "Chart[$final_pos] has " . scalar(@{$chart[$final_pos] || []}) . " items";

        # Search all chart positions for completed Program items
        for my $pos (0 .. $#chart) {
            next unless $chart[$pos];
            for my $item (@{$chart[$pos]}) {
                if ($item->is_complete &&
                    $item->rule->lhs eq 'Program' &&
                    $item->start_pos == 0) {
                    $ir_graph->set_entry_node($item->semantic_value);
                    DEBUG "Set entry_node to: " . (defined $item->semantic_value ? $item->semantic_value->to_string : 'undef') . " (found at chart position $pos)";
                    last;
                }
            }
        }

        return $ir_graph;
    }

    method is_nonterminal($symbol) {
        return exists $nonterminals{$symbol};
    }


    # Shared method to find all valid completion candidates
    method find_candidates($symbol, $start_pos, $parent_item, $parent_end_pos) {
        # Handle end-of-input case: if we're past the input length, check for empty rules
        if ($start_pos >= length($input_text)) {
            # Look for empty rules for this symbol in the grammar
            for my $rule (@grammar_rules) {
                if ($rule->lhs eq $symbol && @{$rule->rhs} == 0) {
                    DEBUG "Found empty rule for $symbol at end of input: " . $rule->lhs . " → ε";
                    # Execute semantic action for empty rule
                    my $semantic_value = $rule->execute_action([], $ir_graph);
                    return [{
                        item => undef,  # No item for empty rule
                        semantic_value => $semantic_value,
                        end_pos => $start_pos
                    }];
                }
            }
            DEBUG "No empty rule found for $symbol at end of input";
            return [];
        }

        # Look for completed items across all chart positions
        my @all_candidates = map {
            $chart[$_] ? grep {
                DEBUG "Checking item: " . $_->to_string . " complete=" . $_->is_complete .
                      " lhs_match=" . ($_->rule->lhs eq $symbol) .
                      " start_pos=" . $_->start_pos . " looking_for=" . $start_pos .
                      " consumed=" . ($_->current_pos > $_->start_pos) .
                      " child_ok=" . $self->could_be_child_of($_, $parent_item);
                $_->is_complete &&
                $_->rule->lhs eq $symbol &&
                $_->start_pos == $start_pos &&
                $self->could_be_child_of($_, $parent_item)
            } @{$chart[$_]} : ()
        } ($start_pos .. $parent_end_pos);

        DEBUG "All candidates for $symbol at $start_pos:";
        for my $cand (@all_candidates) {
            DEBUG "  " . $cand->to_string . " span=" . ($cand->current_pos - $cand->start_pos);
        }

        # Convert items to candidate records
        return [map {
            {
                item => $_,
                semantic_value => $_->semantic_value,
                end_pos => $_->current_pos
            }
        } @all_candidates];
    }

    # Final result selection - prefers longest spans for left-recursive structures
    method find_best_completion($symbol, $start_pos, $parent_item, $parent_end_pos) {
        DEBUG "Finding best completion for $symbol starting at $start_pos (final selection)";
        
        my $candidates = $self->find_candidates($symbol, $start_pos, $parent_item, $parent_end_pos);
        
        return undef unless @$candidates;
        
        my ($best_candidate) = sort {
            my $item_a = $a->{item};
            my $item_b = $b->{item};
            
            # Handle empty rule case
            return 0 unless $item_a && $item_b;
            
            if (@$candidates > 1) {
                # Check if any candidate is a left-recursive expression (contains same symbol on RHS)
                my $has_left_recursive = grep {
                    my $item = $_->{item};
                    $item && $item->rule->rhs_length > 0 && $item->rule->rhs_at(0) eq $item->rule->lhs
                } @$candidates;

                # Check if we have single-token expressions that might be part of larger constructs
                my $has_single_token = grep {
                    my $item = $_->{item};
                    if ($item) {
                        my $rule = $item->rule;
                        # Single token rules that are often part of larger expressions
                        ($rule->lhs eq 'Variable' && $rule->rhs_length == 2) ||  # Variable → $ Identifier
                        ($rule->lhs eq 'StringLiteral' && $rule->rhs_length == 3)  # StringLiteral → ' StringContent '
                    } else { 0 }
                } @$candidates;

                my $has_compound = grep {
                    my $item = $_->{item};
                    if ($item) {
                        my $rule = $item->rule;
                        # Compound expressions (comparisons, operators, etc.)
                        $rule->rhs_length > 3
                    } else { 0 }
                } @$candidates;

                if ($has_left_recursive) {
                    # For left-recursive cases, prefer LONGEST span (complete structure)
                    # This implements the YAEP/MARPA principle from LEFT_RECURSION_OPTIMIZATION.md Section 5.3
                    ($b->{end_pos} - $start_pos) <=> ($a->{end_pos} - $start_pos)
                } elsif ($has_single_token && $has_compound) {
                    # If we have both simple and compound options, strongly prefer compound
                    # This encourages operator formation over premature simple selection
                    ($b->{end_pos} - $start_pos) <=> ($a->{end_pos} - $start_pos) ||
                    # If spans are equal, prefer compound rules
                    ($item_b->rule->rhs_length <=> $item_a->rule->rhs_length)
                } else {
                    # For non-left-recursive cases, prefer longest span (greedy)
                    ($b->{end_pos} - $start_pos) <=> ($a->{end_pos} - $start_pos)
                }
            } else {
                # Single candidate, no sorting needed
                0
            }
        } @$candidates;

        DEBUG "Found best completion: " . ($best_candidate->{item} ? $best_candidate->{item}->to_string : "empty rule");
        return $best_candidate;
    }

    # Reconstruction method - finds actual completed items that were used during parsing
    method find_actual_completion($symbol, $start_pos, $parent_item, $parent_end_pos) {
        DEBUG "Finding actual completion for $symbol starting at $start_pos (reconstruction)";
        
        # Strategy: Instead of trying to calculate where symbols should be,
        # find all completed items for this symbol and pick the one that makes sense
        # within the parent item's span
        
        my @all_completed_items;
        for my $chart_pos (0 .. $#chart) {
            next unless $chart[$chart_pos];
            for my $item (@{$chart[$chart_pos]}) {
                if ($item->is_complete && 
                    $item->rule->lhs eq $symbol &&
                    $item->start_pos >= $start_pos &&  # Must start at or after our position
                    $item->current_pos <= $parent_end_pos) {  # Must end within parent span
                    
                    push @all_completed_items, $item;
                }
            }
        }
        
        DEBUG "Found " . scalar(@all_completed_items) . " completed items for $symbol:";
        for my $item (@all_completed_items) {
            DEBUG "  " . $item->to_string . " span: " . $item->start_pos . "-" . $item->current_pos;
        }
        
        if (!@all_completed_items) {
            # Handle empty rule case
            for my $rule (@grammar_rules) {
                if ($rule->lhs eq $symbol && @{$rule->rhs} == 0) {
                    DEBUG "Using empty rule for $symbol";
                    my $semantic_value = $rule->execute_action([], $ir_graph);
                    return {
                        semantic_value => $semantic_value,
                        end_pos => $start_pos  # Empty rule doesn't advance position
                    };
                }
            }
            
            DEBUG "No completed items found for $symbol at/after position $start_pos";
            DEBUG "Available items in chart:";
            for my $pos (0 .. $#chart) {
                next unless $chart[$pos];
                for my $item (@{$chart[$pos]}) {
                    if ($item->rule->lhs eq $symbol) {
                        DEBUG "  Chart[$pos]: " . $item->to_string . " (complete=" . $item->is_complete . ")";
                    }
                }
            }
            die "Parse failed: Could not find completed parse for '$symbol' at/after position $start_pos";
        }
        
        # For reconstruction, prefer the item that starts closest to our expected position
        # This is more reliable than trying to calculate positions
        my ($best_item) = sort {
            # Prefer items that start exactly at our position
            my $a_exact = ($a->start_pos == $start_pos) ? 0 : 1;
            my $b_exact = ($b->start_pos == $start_pos) ? 0 : 1;
            $a_exact <=> $b_exact ||
            # If neither is exact, prefer the one that starts closest to our position
            abs($a->start_pos - $start_pos) <=> abs($b->start_pos - $start_pos) ||
            # If start positions are equal, prefer shorter spans (more specific)
            ($a->current_pos - $a->start_pos) <=> ($b->current_pos - $b->start_pos)
        } @all_completed_items;
        
        DEBUG "Selected item for reconstruction: " . $best_item->to_string;
        return {
            semantic_value => $best_item->semantic_value,
            end_pos => $best_item->current_pos
        };
    }

    method reconstruct_from_partials($symbol, $start_pos, $parent_end_pos) {
      # Strategy 2: When we can't find a perfect completion,
      # try to reconstruct from available partial information

      # Look for any item that started at the right position for this symbol
      for my $chart_pos ($start_pos .. $parent_end_pos) {
          next unless $chart[$chart_pos];

          for my $item (@{$chart[$chart_pos]}) {
              if ($item->rule->lhs eq $symbol &&
                  $item->start_pos == $start_pos) {

                  # Found an item for this symbol, even if not complete
                  # Return what we can determine
                  return {
                      semantic_value => $item->semantic_value,
                      end_pos => $item->current_pos || $chart_pos
                  };
              }
          }
      }

      # If we still can't find anything, return a placeholder
      return {
          semantic_value => undef,
          end_pos => $start_pos  # No progress made
      };
   }

    method could_be_child_of($child_item, $parent_item) {
      # Check if this child could logically be part of the parent's parse
      return $child_item->current_pos <= $parent_item->current_pos &&
             $child_item->start_pos >= $parent_item->start_pos;
    }

    method find_completed_item($symbol, $start_pos) {
        DEBUG "Finding completed item for $symbol starting at $start_pos";
      # Search through all chart positions from start_pos forward
      for my $chart_pos ($start_pos .. $#chart) {
          DEBUG "Checking chart position $chart_pos";
          next unless $chart[$chart_pos];
          DEBUG "Chart position $chart_pos has items";
          for my $item (@{$chart[$chart_pos]}) {
              DEBUG "Checking item " . $item->to_string;
              if ($item->is_complete &&
                  $item->rule->lhs eq $symbol &&
                  $item->start_pos == $start_pos) {
                  DEBUG "Found completed item: " . $item->to_string;
                  return $item;
              }
          }
      }
      return;
    }

    method collect_child_values($item, $end_pos) {
        my $rule = $item->rule;
        my @rhs = $rule->rhs->@*;
        my @values;

        my @parse_path = $self->reconstruct_parse_path($item, $end_pos);

        for my $i (0..$#rhs) {
            my $s = $rhs[$i];
            if ($self->is_character_class($s)) {
                my $char = substr($input_text, $parse_path[$i]->{pos}, 1);
                push @values, { char => $char };
            }
            elsif ($self->is_nonterminal($s)) {
                    push @values, $parse_path[$i]->{semantic_value};
            } else { # literal no semantic value, just advance position
                push @values, undef;
            }
        }
        return @values;
    }

    method reconstruct_parse_path($completed_item, $end_pos) {
      DEBUG "Reconstructing parse path for " . $completed_item->to_string;
      DEBUG "Item spans from " . $completed_item->start_pos . " to " . $end_pos;
      my $rule = $completed_item->rule;
      my @rhs = $rule->rhs->@*;
      my @path;

      # Start from the beginning of this item
      my $current_pos = $completed_item->start_pos;
      DEBUG "Starting reconstruction at position $current_pos";

      for my $i (0 .. $#rhs) {
          my $symbol = $rhs[$i];
          DEBUG "Processing symbol $symbol at current_pos=$current_pos (step $i of " . scalar(@rhs) . ")";
          if ($self->is_character_class($symbol)) {
              DEBUG "Character class: $symbol";
              # Character: record position and advance
              push @path, {
                  symbol => $symbol,
                  pos => $current_pos,
                  type => 'character'
              };
              $current_pos += 1;
          }
          elsif ($self->is_nonterminal($symbol)) {
              DEBUG "Nonterminal: $symbol";
              DEBUG "Looking for $symbol completion starting at $current_pos (after processing previous symbols)";
              # Nonterminal: find what actually completed here
              my $child_completion = $self->find_actual_completion(
                  $symbol, $current_pos, $completed_item, $end_pos
              );

              if ($child_completion) {
                  push @path, {
                      symbol => $symbol,
                      pos => $current_pos,
                      type => 'nonterminal',
                      semantic_value => $child_completion->{semantic_value},
                      end_pos => $child_completion->{end_pos}
                  };
                  $current_pos = $child_completion->{end_pos};
              }
          }
          else {
              DEBUG "Literal: $symbol";
              # Literal: record position and advance
              push @path, {
                  symbol => $symbol,
                  pos => $current_pos,
                  type => 'literal'
              };
              $current_pos += length($symbol);
          }
      }

      return @path;
    }

    method complete($item, $pos, $agenda) {
        DEBUG "Completing item " . $item->to_string;
        my $rule = $item->rule; # Get the rule that just completed
        my @child_values = $self->collect_child_values($item, $pos);

        # Execute semantic action when rule completes
        my $semantic_value = undef;
        try {
            DEBUG "Executing semantic action for rule: " . $rule->to_string . " (id: " . $rule->id . ")";
            $semantic_value = $rule->execute_action(\@child_values, $ir_graph);
        }
        catch($e) {
            warn "Error executing semantic action for rule " . $rule->id . ": $e";
        }

        $item->set_semantic_value($semantic_value);

        # Standard Earley completion - look for waiting items that could use this completion
        # We need to check positions where items might be waiting for this symbol
        for my $chart_pos (0 .. $item->start_pos) {
            next unless $chart[$chart_pos];
            for my $waiting_item (@{$chart[$chart_pos]}) {
                DEBUG "Checking waiting item " . $waiting_item->to_string;
                next if $waiting_item->is_complete;
                DEBUG "\tWaiting item is not complete";
                next unless defined $waiting_item->next_symbol;
                DEBUG "\tWaiting item has next symbol";
                next unless $waiting_item->next_symbol eq $rule->lhs;

                # Additional check: waiting item should be positioned to consume this completion
                # The waiting item's current position should match where this completion starts
                next unless $waiting_item->current_pos == $item->start_pos;
                DEBUG "\tWaiting item is positioned correctly (current_pos=" . $waiting_item->current_pos . " matches completion start=" . $item->start_pos . ")";

                DEBUG "\tComparing '" . ($waiting_item->next_symbol // 'undef') . "' eq '" . ($rule->lhs // 'undef') . "'";
                DEBUG "\tWaiting item has correct next symbol";

                my $new_item = $waiting_item->advance;
                DEBUG "Set current_pos to $pos for item: " . $new_item->to_string;
                $new_item->set_current_pos($pos);
                DEBUG "\tNew item: " . $new_item->to_string;

                # Check if this item already exists before adding
                my $already_exists = 0;
                for my $existing_item (@{$chart[$pos]}) {
                    if ($existing_item->rule == $new_item->rule &&
                        $existing_item->start_pos == $new_item->start_pos &&
                        $existing_item->dot_pos == $new_item->dot_pos) {
                        DEBUG "Item already exists in chart, skipping";
                        $already_exists = 1;
                        last;
                    }
                }

                if (!$already_exists) {
                    push @$agenda, $new_item;
                    push @{$chart[$pos]}, $new_item;
                }
            }
        }
        DEBUG "Item completed with semantic value: " . (defined $semantic_value ? $semantic_value :
  'undef');
    }

    method scan_character($item, $pos, $text) {
        return if $pos >= length($text);

        my $char = substr($text, $pos, 1);
        my $expected = $item->next_symbol;

        if ($self->matches_character_class($char, $expected)) {
            my $new_item = $item->advance($char);
            $new_item->set_current_pos( $pos + 1 );

            # Store the matched character for semantic actions
            if ($expected eq 'Char') {
                $new_item->set_semantic_value({ char => $char });
            }

            push @{$chart[$pos + 1]}, $new_item;
        }
    }

    method scan_literal($item, $pos, $text) {
        DEBUG "Scanning literal at position $pos";
        my $literal = $item->next_symbol;
        DEBUG "Literal: $literal";
        my $lit_length = length($literal);

        DEBUG "comparing $pos + $lit_length to " . length($text);
        return if $pos + $lit_length > length($text);
        DEBUG "Literal length: $lit_length";

        my $text_part = substr($text, $pos, $lit_length);
        DEBUG "Text part: $text_part";
        if ($text_part eq $literal) {
            DEBUG "Matched literal: $literal";
            my $new_item = $item->advance($literal);
            $new_item->set_current_pos($pos + $lit_length);

            push @{$chart[$pos + $lit_length]}, $new_item;
        }
    }

    method predict($item, $pos, $agenda) {
        my $next_sym = $item->next_symbol;
        DEBUG "Predicting for symbol: $next_sym at position $pos";

        for my $rule (@grammar_rules) {
            if ($rule->lhs eq $next_sym) {
                DEBUG "Found rule to predict: " . $rule->to_string;

                # Standard Earley handling for left-recursive rules
                # Let the fixed-point computation handle recursion naturally

                my $predicted_item = EarleyItem->new(
                    rule => $rule,
                    start_pos => $pos,
                    current_pos => $pos
                );

                # Check if this exact item already exists using content-based comparison
                my $already_exists = 0;
                for my $existing_item (@{$chart[$pos]}) {
                    if ($existing_item->rule == $rule &&
                        $existing_item->start_pos == $pos &&
                        $existing_item->dot_pos == 0) {
                        DEBUG "Rule already predicted, skipping";
                        $already_exists = 1;
                        last;
                    }
                }

                if (!$already_exists) {
                    DEBUG "Adding predicted item: " . $predicted_item->to_string;
                    push @$agenda, $predicted_item;
                    push @{$chart[$pos]}, $predicted_item;
                }
            }
        }
    }

    method is_character_class($symbol) {
        return $symbol =~ /^(Letter|LetterDigit|Char|Whitespace|CommentLineChar|VerticalSpace)$/;
    }


    method matches_character_class($char, $class) {
        for ($class) {
            if ($_ eq 'Letter') { return $char =~ /[a-zA-Z]/ }
            if ($_ eq 'LetterDigit') { return $char =~ /[a-zA-Z0-9]/ }
            if ($_ eq 'Char') { return $char =~ /[^"']/ }  # Any char except quotes
            if ($_ eq 'Whitespace') { return $char =~ /\s/ }
            if ($_ eq 'CommentLineChar') { return $char =~ /[^\n]/ }  # Any char except newline
            if ($_ eq 'VerticalSpace') { 
                # Unicode-aware vertical space: LF, VT, FF, CR, NEL, Line Separator, Paragraph Separator
                return $char =~ /[\x{A}\x{B}\x{C}\x{D}\x{0085}\x{2028}\x{2029}]/;
            }
            return 0;
        }
    }
}

# Command-line argument processing
use Getopt::Long;

my $help;

GetOptions(
    'h|help' => \$help,
) or die "Error in command line arguments\n";

if ($help) {
    print <<'USAGE';
Usage: chalk [filename]
  -h, --help    Show this help message

If no filename is given, code is read from STDIN.
USAGE
    exit 0;
}

my $perl_code;

if (@ARGV) {
    # Read from file
    my $filename = $ARGV[0];
    open my $fh, '<', $filename or die "Cannot open file '$filename': $!\n";
    $perl_code = do { local $/; <$fh> };
    close $fh;
} else {
    # Read from STDIN
    $perl_code = do { local $/; <STDIN> };
}

die "No code to execute\n" unless defined $perl_code && length $perl_code;

# Parse and execute the code
my $parser = ScanlessEarleyParser->new();
my $ir_graph = $parser->parse($perl_code);

# Run optimizations and cleanup (peephole optimizations run in execute_threaded)
# $ir_graph->cleanup_orphaned_nodes();  # Don't call cleanup here - it's called in execute_threaded
$ir_graph->dump_graph();  # Check what's in graph before execute_threaded

# Execute the code
$ir_graph->execute_threaded();
