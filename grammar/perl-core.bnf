# Chalk Perl Grammar - Core Rules
# Format: LHS -> RHS
# Terminals in 'quotes', regexes as %PATTERN_NAME%, nonterminals unquoted
# Empty RHS means epsilon rule

# Top level
Program -> StatementList
Program -> WS_OPT StatementList WS_OPT
Program -> Shebang StatementList WS_OPT

# Statement lists
StatementList ->
StatementList -> Statement
StatementList -> Statement ';' StatementList
StatementList -> Statement StatementList

# Core statement types
Statement -> Statement StatementModifier
Statement -> QLikeValue ElementIndexChain
Statement -> AdjustBlock
Statement -> Block
Statement -> BuiltinFunctionCall
Statement -> ClassDecl
Statement -> Comment
Statement -> ControlFlowStatement
Statement -> DieExpr
Statement -> EllipsisStatement
Statement -> EvalBlock
Statement -> Expression
Statement -> FieldDecl
Statement -> FunctionCall
Statement -> LineStatement
Statement -> ListOperatorCall
Statement -> LoopBlock
Statement -> PackageDecl
Statement -> PrintExpr
Statement -> QLikeValue
Statement -> RequireStatement
Statement -> ReturnStatement
Statement -> SubroutineDecl
Statement -> UseStatement
Statement -> VariableDecl
Statement -> WarnExpr
Statement -> IfStatement
Statement -> UnlessStatement

# Conditionals
IfStatement -> 'if' ConditionalStatement
UnlessStatement -> 'unless' ConditionalStatement

ConditionalStatement -> '(' Expression ')' Block
ConditionalStatement -> ConditionalStatement ElsifChain
ConditionalStatement -> ConditionalStatement ElseBlock

ElsifChain -> 'elsif' ConditionalStatement
ElseBlock -> 'else' Block

# Blocks
Block -> '{' StatementList '}'
Block -> '{' '}'

AdjustBlock -> %RE_ADJUST% Block

# Loops
LoopBlock -> ForStatement
LoopBlock -> WhileStatement

ForStatement -> %RE_FOR% '(' Expression ';' Expression ';' Expression ')' Block
ForStatement -> %RE_FOR% '(' ';' Expression ';' Expression ')' Block
ForStatement -> %RE_FOR% '(' Expression ';' ';' Expression ')' Block
ForStatement -> %RE_FOR% '(' Expression ';' Expression ';' ')' Block
ForStatement -> %RE_FOR% '(' ';' ';' ')' Block
ForStatement -> %RE_FOR% VariableDecl '(' Expression ')' Block
ForStatement -> %RE_FOR% '(' Expression ')' Block

WhileStatement -> 'while' '(' Expression ')' Block

# Comments and line statements
LineStatement -> Comment
Shebang -> %RE_SHEBANG%
Comment -> %RE_COMMENT%

# This file would continue with all 389 rules...
# But in a simple line-by-line format that's easy to parse
