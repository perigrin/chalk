# ============================================================================
# Chalk BNF Grammar - Restricted Perl Subset for Compilation
# ============================================================================
#
# DESIGN PRINCIPLES:
#
# 1. **Classes Only - No Packages**
#    Chalk exclusively uses modern Perl `class` syntax (5.40+). The `package`
#    keyword is not supported in chalk.bnf. Classes provide clear object
#    semantics suitable for compilation, while packages are namespace containers
#    with ambiguous behavior.
#
# 2. **Static Parseability**
#    All constructs must be statically parseable without runtime information.
#    This excludes symbolic references, eval (both STRING and BLOCK forms),
#    most special variables, and other dynamic features that complicate
#    static analysis.
#
# 3. **Alignment with Standard Perl**
#    Where beneficial for static parsing, we adopt restrictions from the
#    Standard Perl specification (https://metacpan.org/pod/standard):
#    - All hash keys must be quoted (no bareword auto-quoting)
#    - No HEREDOCs (cannot be expressed in BNF)
#    - No indirect object notation (ambiguous syntax)
#    - Function calls may omit parentheses in unambiguous contexts
#
# 4. **Compilation Target**
#    Grammar designed to enable compilation to intermediate representations
#    (Sea of Nodes IR) with clear semantics suitable for optimization and
#    formal verification.
#
# 5. **Self-Hosting**
#    The grammar must parse all Chalk library code in lib/. Currently at
#    100% self-hosting (26/26 files parse successfully).
#
# KEY EXCLUSIONS:
#
# - `package` declarations (use `class` instead)
# - eval (both STRING and BLOCK forms - no runtime code evaluation)
# - Symbolic references: $$var, &{$code}, *{$glob}
# - Typeglobs and formats
# - Most special variables (except $1, $2, @-, etc.)
# - Indirect object syntax: new Class @args
# - Barewords (except keywords and special cases)
# - HEREDOCs (per Standard Perl - cannot express in BNF)
# - Old-style OO (Moose, Moo, bless) - use `class` instead
#
# OPERATOR PRECEDENCE:
#
# Operator precedence is validated by the Chalk::Semiring::Precedence module,
# not encoded in the grammar structure. The grammar provides a flat expression
# structure organized by semantic groupings (Assignment, Ternary, LogicalOp,
# ArithmeticOp, etc.), and the precedence semiring validates that operator
# precedence relationships match Perl semantics during parsing.
#
# See lib/Chalk/Semiring/Precedence.pm for the precedence table.
#
# ============================================================================

# Pattern definitions
%WS% = /[ \t\r\n]+/
%COMMENT% = /#[^\n]*/
# Reserved keywords excluded from barewords via negative lookahead
# Note: sub/method are reserved to prevent FunctionCall from matching SubroutineDeclaration
%BAREWORD% = /(?!(?:sub|method|class|field|if|unless|elsif|else|while|until|for|foreach|return|last|next|redo|my|our|state|use|no|require|and|or|not|eq|ne|lt|gt|le|ge|cmp|isa|true|false|__FILE__|__LINE__)\b)[a-zA-Z_][a-zA-Z0-9_]*/
%BAREWORD_ANY% = /[a-zA-Z_][a-zA-Z0-9_]*/
%SPECIAL_IDENTIFIER% = /[0-9]+|[&`'+@!$-]|^[A-Z]|\{[^}]+\}/
%INTEGER% = /[0-9]+/
%FLOAT% = /[0-9]+\.[0-9]+/
%VERSION% = /[0-9]+(?:\.[0-9]+){2,}/
%SHEBANG% = /#!.*\n/
%SINGLE_QUOTED_STRING% = /'(?:[^'\\]|\\.)*'/
%DOUBLE_QUOTED_STRING% = /"(?:[^"\\]|\\.)*"/
%REGEX_CONTENT% = /(?:[^\/\\]|\\.)+/
%REGEX_FLAGS% = /[msixpodualngc]*/
%STRING_COMPARE_OP% = /eq|ne|lt|gt|le|ge|cmp/
%NUM_COMPARE_OP% = /==|!=|<=>|<=|>=|<|>/
%REGEX_MATCH_OP% = /=~|!~/
%ASSIGN_OP% = /\/\/=|\|\|=|\+=|-=|\.=/
%ARITHMETIC_OP% = /[+\-*\/]/
%BITWISE_AND_OP% = /&(?!&)/
%BITWISE_OR_OP% = /\|(?!\|)/
%BITWISE_XOR_OP% = /\^/
%SHIFT_OP% = /<<|>>/
%ISA_COMPARE_OP% = /\bisa\b/

# ============================================================================
# GRAMMAR RULES - Organized Generic → Specific
# ============================================================================

# Start symbol (most generic)
Program -> WS_OPT StatementList WS_OPT
Program -> Shebang WS_OPT StatementList WS_OPT

# Statement lists
StatementList -> Statement WS_OPT ';' WS_OPT StatementList
StatementList -> Statement WS_OPT StatementList
StatementList -> Statement WS_OPT
StatementList ->

# Statements
Statement -> ExpressionList
Statement -> Block
Statement -> UseStatement
Statement -> VariableDeclaration
Statement -> ReturnStatement
Statement -> LoopControl
Statement -> BreakStatement
Statement -> ContinueStatement
Statement -> PostfixConditionalStatement
Statement -> PostfixLoopStatement

# Postfix conditional statement modifier (if/unless after statement)
PostfixConditionalStatement -> Statement WS_OPT ConditionalKeyword WS_OPT Expression

# Postfix loop statement modifier (for/foreach/while/until after statement)
# Examples: print $_ for @items;  print while <>;
PostfixLoopStatement -> Statement WS_OPT 'for' WS_OPT Expression
PostfixLoopStatement -> Statement WS_OPT 'foreach' WS_OPT Expression
PostfixLoopStatement -> Statement WS_OPT 'while' WS_OPT Expression
PostfixLoopStatement -> Statement WS_OPT 'until' WS_OPT Expression

# Blocks (literal blocks and block-containing statements)
Block -> ClassDeclaration
Block -> MethodDeclaration
Block -> AdjustBlock
Block -> LexicalSubroutine
Block -> SubroutineDeclaration
Block -> ConditionalStatement
Block -> WhileStatement
Block -> ForStatement
Block -> '{' WS_OPT StatementList WS_OPT '}'

ClassDeclaration -> 'class' WS_OPT QualifiedIdentifier WS_OPT Block
ClassDeclaration -> 'class' WS_OPT QualifiedIdentifier WS_OPT AttributeList WS_OPT Block

# Conditional keyword
ConditionalKeyword -> 'if'
ConditionalKeyword -> 'unless'

# Elsif clause (recursive for arbitrary chaining)
ElsifClause -> 'elsif' WS_OPT '(' WS_OPT Expression WS_OPT ')' WS_OPT Block
ElsifClause -> 'elsif' WS_OPT '(' WS_OPT Expression WS_OPT ')' WS_OPT Block WS_OPT ElsifClause
ElsifClause -> 'elsif' WS_OPT '(' WS_OPT Expression WS_OPT ')' WS_OPT Block WS_OPT 'else' WS_OPT Block

# Conditional statements (block form)
ConditionalStatement -> ConditionalKeyword WS_OPT '(' WS_OPT Expression WS_OPT ')' WS_OPT Block
ConditionalStatement -> ConditionalKeyword WS_OPT '(' WS_OPT Expression WS_OPT ')' WS_OPT Block WS_OPT 'else' WS_OPT Block
ConditionalStatement -> ConditionalKeyword WS_OPT '(' WS_OPT Expression WS_OPT ')' WS_OPT Block WS_OPT ElsifClause

# While loops
WhileStatement -> 'while' WS_OPT '(' WS_OPT Expression WS_OPT ')' WS_OPT Block

# For loops (only foreach-style with explicit variable)
# 'for' and 'foreach' are synonyms in Perl
ForStatement -> 'for' WS_OPT LexicalDeclarator WS_OPT Variable WS_OPT '(' WS_OPT Expression WS_OPT ')' WS_OPT Block
ForStatement -> 'foreach' WS_OPT LexicalDeclarator WS_OPT Variable WS_OPT '(' WS_OPT Expression WS_OPT ')' WS_OPT Block

# Return statements
ReturnStatement -> 'return'
ReturnStatement -> 'return' WS_OPT Expression
ReturnStatement -> 'return' WS_OPT '(' WS_OPT ExpressionList WS_OPT ')'

# Break and Continue statements
BreakStatement -> 'break' WS_OPT
ContinueStatement -> 'continue' WS_OPT

# Loop control (Perl-style last/next)
LoopControl -> 'last'
LoopControl -> 'next'

# Declarations

# Use statements
UseStatement -> 'use' WS_OPT String  # use 5.42.0 (version string)
UseStatement -> 'use' WS_OPT QualifiedIdentifier  # use Module
UseStatement -> 'use' WS_OPT QualifiedIdentifier WS_OPT QuotedWordList  # use Module qw(...)
UseStatement -> 'use' WS_OPT QualifiedIdentifier WS_OPT String  # use experimental 'class'
UseStatement -> 'use' WS_OPT QualifiedIdentifier WS_OPT ExpressionList  # use overload ... => ...

# Lexical declarator
LexicalDeclarator -> 'my'
LexicalDeclarator -> 'state'
LexicalDeclarator -> 'field'

# Variable declarations (without assignment - assignment is handled by Assignment rule)
VariableDeclaration -> LexicalDeclarator WS_OPT Variable
VariableDeclaration -> LexicalDeclarator WS_OPT Variable WS_OPT AttributeList
VariableDeclaration -> LexicalDeclarator WS_OPT '(' WS_OPT VariableList WS_OPT ')'  # List declaration: my ($a, $b)

# Variable list for list assignment
VariableList -> Variable WS_OPT ',' WS_OPT VariableList
VariableList -> Variable

# Method declarations
MethodDeclaration -> 'method' WS_OPT Identifier WS_OPT '(' WS_OPT ParameterList WS_OPT ')' WS_OPT Block
MethodDeclaration -> 'method' WS_OPT Identifier WS_OPT Block

# ADJUST blocks
AdjustBlock -> 'ADJUST' WS_OPT Block

# Subroutines (package-level)
SubroutineDeclaration -> 'sub' WS_OPT QualifiedIdentifier WS_OPT '(' WS_OPT ParameterList WS_OPT ')' WS_OPT Block
SubroutineDeclaration -> 'sub' WS_OPT QualifiedIdentifier WS_OPT Block

# Lexical subs
LexicalSubroutine -> LexicalDeclarator WS_OPT SubroutineDeclaration

# Anonymous subroutines (for closures)
AnonymousSub -> 'sub' WS_OPT '(' WS_OPT ParameterList WS_OPT ')' WS_OPT Block
AnonymousSub -> 'sub' WS_OPT Block

# ============================================================================
# Expression Grammar - Flat Structure with Precedence Semiring Validation
# ============================================================================
#
# DESIGN: Flat grammar with semantic groupings, validated by precedence semiring
#
# Previously, this grammar used "precedence climbing" where operator precedence
# was encoded through nested rule hierarchies (Assignment -> Ternary ->
# LogicalOr -> ... -> Primary). This created 13 pass-through rules that were
# pure parser overhead with no semantic value.
#
# CURRENT ARCHITECTURE:
#
# The grammar now provides a flat structure organized by SEMANTIC groupings:
#   - Assignment (=, +=, -=, etc.)
#   - Ternary (?:)
#   - LogicalOp (||, &&, or, and, //)
#   - ComparisonOp (==, !=, eq, ne, <, >, isa, =~, !~)
#   - ConcatenationOp (.)
#   - RangeOp (..)
#   - ArithmeticOp (+, -, *, /)
#   - Unary (!, not, -, +, ++, --, \)
#   - Postfix (++, --)
#
# Operator precedence is validated by the Chalk::Semiring::Precedence module
# during parsing, not encoded in grammar structure.
#
# BENEFITS:
#   - 13 fewer grammar rules (reduced overhead)
#   - Precedence errors generate specific, actionable error messages
#   - Precedence table is centralized and easier to maintain
#   - Semantic groupings enable polymorphic dispatch in IR generation
#
# See lib/Chalk/Semiring/Precedence.pm for the precedence validation logic.

# ============================================================================
# EXPRESSION GRAMMAR - Flattened with Semantic Groupings
# ============================================================================
# All operator precedence validated by Precedence semiring
# Precedence ladder eliminated - Expression directly references all semantic groups
# Semantic groupings preserved for polymorphic dispatch in semantic actions

# Expression entry point - directly references all semantic groupings
# Atomic values and base cases
Expression -> Literal
Expression -> Variable
Expression -> Identifier  # Bareword (can be function name, method name, or string in context)
Expression -> YaddaYadda
Expression -> FunctionCall
Expression -> BuiltinOp
Expression -> ListOp
Expression -> ReferenceConstructor
Expression -> AnonymousSub
Expression -> PostfixDeref  # Postfix dereferencing: ->@* and ->%*
Expression -> '(' WS_OPT Expression WS_OPT ')'  # Parenthesized expression
Expression -> '(' WS_OPT ExpressionList WS_OPT ')'  # Parenthesized list
# Operators
Expression -> Assignment
Expression -> Ternary
Expression -> LogicalOp
Expression -> ComparisonOp
Expression -> ConcatenationOp
Expression -> RangeOp
Expression -> ArithmeticOp
Expression -> BitwiseAndOp
Expression -> BitwiseOrOp
Expression -> BitwiseXorOp
Expression -> ShiftOp
Expression -> Unary
Expression -> Postfix

# Assignment operators (right-associative)
Assignment -> Expression WS_OPT '=' WS_OPT Expression
Assignment -> Expression WS_OPT %ASSIGN_OP% WS_OPT Expression
Assignment -> VariableDeclaration WS_OPT '=' WS_OPT Expression  # my $x = 1, field $y = 0 (for declarations with defaults)

# Ternary operator (right-associative)
Ternary -> Expression WS_OPT '?' WS_OPT Expression WS_OPT ':' WS_OPT Expression

# Logical operators (left-associative)
# Phase 4: Flattened from LogicalOr + LogicalAnd
LogicalOp -> Expression WS_OPT '||' WS_OPT Expression
LogicalOp -> Expression WS_OPT 'or' WS_OPT Expression
LogicalOp -> Expression WS_OPT '//' WS_OPT Expression
LogicalOp -> Expression WS_OPT '&&' WS_OPT Expression
LogicalOp -> Expression WS_OPT 'and' WS_OPT Expression

# Comparison and regex match operators (left-associative)
# Phase 4: Flattened from Comparison + RegexMatch
# Precedence handled by Precedence semiring
ComparisonOp -> Expression WS_OPT %NUM_COMPARE_OP% WS_OPT Expression
ComparisonOp -> Expression WS_OPT %STRING_COMPARE_OP% WS_OPT Expression
ComparisonOp -> Expression WS_OPT %ISA_COMPARE_OP% WS_OPT QualifiedIdentifier
ComparisonOp -> Expression WS_OPT %ISA_COMPARE_OP% WS_OPT Expression
ComparisonOp -> Expression WS_OPT %REGEX_MATCH_OP% WS_OPT Expression
# Bare regex match: $x =~ /pattern/flags (shorthand for m/pattern/flags)
ComparisonOp -> Expression WS_OPT %REGEX_MATCH_OP% WS_OPT '/' RegexContent '/' RegexFlags

# String concatenation operator (left-associative)
ConcatenationOp -> Expression WS_OPT '.' WS_OPT Expression

# Range operator (non-associative, also flip-flop in scalar context)
RangeOp -> Expression WS_OPT '..' WS_OPT Expression

# Arithmetic operators (left-associative)
# Phase 4: Flattened from Additive + Multiplicative
# Precedence handled by Precedence semiring
ArithmeticOp -> Expression WS_OPT %ARITHMETIC_OP% WS_OPT Expression

# Bitwise operators (left-associative)
# Precedence handled by Precedence semiring: shift > and > xor > or
BitwiseAndOp -> Expression WS_OPT %BITWISE_AND_OP% WS_OPT Expression
BitwiseOrOp -> Expression WS_OPT %BITWISE_OR_OP% WS_OPT Expression
BitwiseXorOp -> Expression WS_OPT %BITWISE_XOR_OP% WS_OPT Expression
ShiftOp -> Expression WS_OPT %SHIFT_OP% WS_OPT Expression

# Unary prefix operators (right-associative)
Unary -> '!' WS_OPT Expression
Unary -> 'not' WS_OPT Expression
Unary -> '-' WS_OPT Expression
Unary -> '+' WS_OPT Expression
Unary -> '++' WS_OPT Expression
Unary -> '--' WS_OPT Expression
Unary -> '\\' WS_OPT Expression  # Reference operator: \$var, \@array, \%hash
Unary -> '~' WS_OPT Expression   # Bitwise NOT operator

# Postfix operators
Postfix -> Variable '++'
Postfix -> Variable '--'

# Expression lists (with optional trailing commas)
ExpressionList -> Expression WS_OPT ',' WS_OPT ExpressionList
ExpressionList -> Expression WS_OPT ','  # Trailing comma
ExpressionList -> Expression
ExpressionList -> Expression WS_OPT '=>' WS_OPT Expression  # Fat comma pair
ExpressionList -> Expression WS_OPT '=>' WS_OPT Expression WS_OPT ','  # Fat comma pair with trailing comma
ExpressionList -> Expression WS_OPT '=>' WS_OPT Expression WS_OPT ',' WS_OPT ExpressionList  # Pairs with more
ExpressionList -> %BAREWORD_ANY% WS_OPT '=>' WS_OPT Expression  # Bareword hash key (auto-quoted, allows keywords)
ExpressionList -> %BAREWORD_ANY% WS_OPT '=>' WS_OPT Expression WS_OPT ','  # Bareword key with trailing comma
ExpressionList -> %BAREWORD_ANY% WS_OPT '=>' WS_OPT Expression WS_OPT ',' WS_OPT ExpressionList  # Bareword key with more
ExpressionList ->

# Yada-yada operator - placeholder that throws "Unimplemented" when evaluated
YaddaYadda -> '...'

# Function and method calls
FunctionCall -> Identifier '(' WS_OPT ExpressionList WS_OPT ')'  # Function call
FunctionCall -> Identifier '(' WS_OPT ')'  # Function call with no args
FunctionCall -> Identifier WS_ELEMENT Expression  # Function call without parens: foo 1, 2
FunctionCall -> QualifiedIdentifier WS_OPT '->' MethodName WS_OPT '(' WS_OPT ExpressionList WS_OPT ')'  # Class method call
FunctionCall -> QualifiedIdentifier WS_OPT '->' WS_OPT MethodName '(' WS_OPT ')'  # Class method call with no args
FunctionCall -> Variable '->' '(' WS_OPT ExpressionList WS_OPT ')'  # Coderef call: $coderef->($arg)
FunctionCall -> Variable '->' '(' WS_OPT ')'  # Coderef call with no args
FunctionCall -> MethodCall  # Delegate to instance method calls

# Method calls - can be invoked on any expression that returns an object reference
# Examples: $obj->method, ($a || $b)->foo, foo()->bar, $obj->m1->m2
# Uses MethodName instead of Identifier to allow reserved words like 'method' and 'sub' as method names
MethodCall -> Expression WS_OPT '->' WS_OPT MethodName '(' WS_OPT ExpressionList WS_OPT ')'  # expr->method($args)
MethodCall -> Expression WS_OPT '->' WS_OPT MethodName '(' WS_OPT ')'  # expr->method() (empty parens)
MethodCall -> Expression WS_OPT '->' WS_OPT MethodName  # expr->method (without parens)
# Qualified method calls - for SUPER::method, Package::method patterns
# Examples: $self->SUPER::method(), $obj->Some::Package::method()
MethodCall -> Expression WS_OPT '->' WS_OPT QualifiedIdentifier '(' WS_OPT ExpressionList WS_OPT ')'  # expr->Package::method($args)
MethodCall -> Expression WS_OPT '->' WS_OPT QualifiedIdentifier '(' WS_OPT ')'  # expr->Package::method()

# Postfix dereference operators - can apply to any expression returning a reference
# Examples: $var->@*, $obj->method->@*, foo()->@*, ($x || $y)->@*, $var->@*->%*
PostfixDeref -> Expression '->' PostfixDerefOp

# Deref operators: ->@* or ->%*
PostfixDerefOp -> '@' '*'  # Array deref
PostfixDerefOp -> '%' '*'  # Hash deref

# Built-in operators - delegates to FunctionCall with optimization hook
# This pass-through rule allows the BuiltinOp semantic action to detect known
# builtins (exists, defined, length, blessed, etc.) and generate specialized
# IR nodes for better optimization, while falling back to FunctionCall for unknown cases.
BuiltinOp -> FunctionCall

# List operations (map, grep, all, any)
ListOp -> 'map' WS_OPT Block WS_OPT Expression
ListOp -> 'grep' WS_OPT Block WS_OPT Expression
ListOp -> 'all' WS_OPT Block WS_OPT Expression
ListOp -> 'any' WS_OPT Block WS_OPT Expression

# Reference constructors (arrays and hashes)
ReferenceConstructor -> '[' WS_OPT ExpressionList WS_OPT ']'  # Array constructor
ReferenceConstructor -> '[' WS_OPT ']'  # Empty array
ReferenceConstructor -> '{' WS_OPT ExpressionList WS_OPT '}'  # Hash constructor
ReferenceConstructor -> '{' WS_OPT '}'  # Empty hash

# ============================================================================
# HELPER RULES AND TERMINALS (Most specific)
# ============================================================================

# Parameter lists (for method/sub signatures)
ParameterList -> Variable
ParameterList -> Variable WS_OPT ',' WS_OPT ParameterList
ParameterList -> Assignment
ParameterList -> Assignment WS_OPT ',' WS_OPT ParameterList
ParameterList ->  # Empty parameter list

# Attribute lists (for fields and classes)
AttributeList -> Attribute
AttributeList -> Attribute WS_OPT AttributeList

# Attributes
Attribute -> ':param'
Attribute -> ':reader'
Attribute -> ':reader' '(' Identifier ')'
Attribute -> ':isa' '(' QualifiedIdentifier ')'

# Qualified identifiers for fully-qualified subs
QualifiedIdentifier -> Identifier
QualifiedIdentifier -> Identifier '::' QualifiedIdentifier

# Variables (lvalues only - things that can be assigned to)
Variable -> ScalarVar
Variable -> ArrayVar
Variable -> HashVar
Variable -> ArraySize

# Variable names allow keywords (e.g., $class, $if, $while are valid in Perl)
ScalarVar -> '$' %BAREWORD_ANY%
ScalarVar -> '$' %SPECIAL_IDENTIFIER%
ArrayVar -> '@' %BAREWORD_ANY%
ArrayVar -> '@' %SPECIAL_IDENTIFIER%
HashVar -> '%' %BAREWORD_ANY%
HashVar -> '%' %SPECIAL_IDENTIFIER%

# Array size
ArraySize -> '$#' %BAREWORD%         # $#array
ArraySize -> '$#' '$' %BAREWORD%     # $#$arrayref

# Array/Hash element access
Variable -> ScalarVar '[' Expression ']'              # $arr[0]
Variable -> ScalarVar '{' Expression '}'              # $hash{key}
Variable -> ScalarVar '{' %BAREWORD_ANY% '}'          # $hash{class} - bareword key (auto-quoted, allows keywords)
Variable -> ArrayVar '[' Expression ']'               # @arr[0..5] (slice with range expr)

# Curly-brace dereferencing (for use in builtin functions like keys, values)
Variable -> '%' '{' Expression '}'                    # %{$hashref} - hash dereference
Variable -> '@' '{' Expression '}'                    # @{$arrayref} - array dereference

# Arrow notation (method-style dereference)
Variable -> Variable '->' '[' Expression ']'          # $ref->[0]
Variable -> Variable '->' '{' Expression '}'          # $ref->{key}
Variable -> Variable '->' '{' %BAREWORD_ANY% '}'      # $ref->{class} - bareword key (auto-quoted, allows keywords)

# Method calls on Variables become Variables to allow further dereferencing
# This allows patterns like: $obj->method->@*, $obj->method->[0], etc.
Variable -> Variable '->' Identifier                  # $var->method (method call without parens)
Variable -> Variable '->' Identifier '(' WS_OPT ExpressionList WS_OPT ')'  # $var->method($args)

# Chained subscripts without arrows (Perl allows omitting arrows between subscripts)
Variable -> Variable '[' Expression ']'               # $ref->[0][1] or $ref->[0]{key}
Variable -> Variable '{' Expression '}'               # $ref->{key1}{key2} or $array->[0]{key}
Variable -> Variable '{' %BAREWORD_ANY% '}'           # $ref->{key1}{class} - bareword key (auto-quoted, allows keywords)

# Postfix dereferencing on Variables - for patterns like $context->children->@*
Variable -> Variable '->' '@' '*'                     # $var->@* (array postfix deref)
Variable -> Variable '->' '%' '*'                     # $var->%* (hash postfix deref)

# Subscript access on function/method call results (for patterns like foo()->{key}, $obj->method()->{key})
# These rules enable chained access: $self->to_hash()->{attributes}, Class->new()->[0]
Variable -> FunctionCall '->' '{' Expression '}'         # foo()->{key}, $obj->method()->{key}
Variable -> FunctionCall '->' '{' %BAREWORD_ANY% '}'     # foo()->{bareword}
Variable -> FunctionCall '->' '[' Expression ']'         # foo()->[0], $obj->method()->[0]

# Note: Coderef calls have been moved to FunctionCall
# since they are pure invocations (rvalues), not chained operations

# Literals
Literal -> Number
Literal -> String
Literal -> QuotedWordList
Literal -> RegexPattern
Literal -> RegexSubstitution
Literal -> EmptyList
Literal -> 'undef'
Literal -> 'true'
Literal -> 'false'
Literal -> '__FILE__'
Literal -> '__LINE__'

EmptyList -> '(' WS_OPT ')'

# Strings - only regular quoted strings
# Note: Keep SingleQuotedString and DoubleQuotedString separate because they have
# different optimization characteristics: single-quoted strings are literal,
# double-quoted strings support interpolation and require runtime processing.
String -> SingleQuotedString
String -> DoubleQuotedString
String -> %VERSION%

SingleQuotedString -> %SINGLE_QUOTED_STRING%
DoubleQuotedString -> %DOUBLE_QUOTED_STRING%

# Quote operators - only qw()
# WS_OPT allows whitespace/newlines inside qw() for multiline word lists
QuotedWordList -> 'qw' '(' WS_OPT WordList WS_OPT ')'

# Words in qw() can be any bareword (including keywords), colon-prefixed symbols, or qualified identifiers
# BAREWORD_ANY matches all identifiers including keywords (no negative lookahead)
Word -> Word '::' Word  # Qualified identifier (e.g., Foo::Bar::Baz, class::field)
Word -> %BAREWORD_ANY%
Word -> ':' %BAREWORD_ANY%

WordList -> Word
WordList -> Word WS_OPT WordList

# Regex patterns
RegexPattern -> 'qr' '/' RegexContent '/' RegexFlags
RegexPattern -> 'm' '/' RegexContent '/' RegexFlags

# Regex substitution
RegexSubstitution -> 's' '/' RegexContent '/' RegexContent '/' RegexFlags

RegexContent -> %REGEX_CONTENT%
RegexContent ->  # Empty regex content (for s/pattern// with no replacement)

RegexFlags -> %REGEX_FLAGS%
RegexFlags ->

# Numbers
Number -> %FLOAT%
Number -> %INTEGER%

# Identifiers
Identifier -> %BAREWORD%

# Method names - can be any bareword including reserved words like 'method' and 'sub'
# This is needed because these are reserved to prevent FunctionCall matching SubroutineDeclaration,
# but they're still valid method names in method call contexts.
MethodName -> %BAREWORD_ANY%

# Shebang
Shebang -> %SHEBANG%

# Whitespace (includes comments - tagged for later processing)
WS_OPT ->
WS_OPT -> WS_ELEMENT WS_OPT

WS_ELEMENT -> %WS%
WS_ELEMENT -> %COMMENT%
