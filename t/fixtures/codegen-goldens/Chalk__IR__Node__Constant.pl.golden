use 5.42.0;
use utf8;
use experimental 'class';
use Chalk::IR::Node;
class Chalk::IR::Node::Constant :isa(Chalk::IR::Node) {
    field $value :param :reader;
    field $const_type :param :reader = 'string';
    method operation() {
        'Constant'
    }
    method content_hash() {
        return join('|', 'Constant', "const_type=$const_type", 'value=' . defined($value) ? $value : undef);
    }
}
